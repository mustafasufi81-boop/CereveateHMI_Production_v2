{
  "version": 1,
  "disable_existing_loggers": false,
  "formatters": {
    "json": {
      "()": "pythonjsonlogger.jsonlogger.JsonFormatter",
      "format": "%(asctime)s %(name)s %(levelname)s %(message)s %(pathname)s %(lineno)d"
    },
    "text": {
      "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s",
      "datefmt": "%Y-%m-%d %H:%M:%S"
    }
  },
  "handlers": {
    "console": {
      "class": "logging.StreamHandler",
      "level": "INFO",
      "formatter": "text",
      "stream": "ext://sys.stdout"
    },
    "file": {
      "class": "logging.handlers.RotatingFileHandler",
      "level": "INFO",
      "formatter": "json",
      "filename": "logs/mqtt_subscriber.log",
      "maxBytes": 104857600,
      "backupCount": 10
    },
    "error_file": {
      "class": "logging.handlers.RotatingFileHandler",
      "level": "ERROR",
      "formatter": "json",
      "filename": "logs/mqtt_subscriber_error.log",
      "maxBytes": 104857600,
      "backupCount": 10
    },
    "security_file": {
      "class": "logging.handlers.RotatingFileHandler",
      "level": "WARNING",
      "formatter": "json",
      "filename": "logs/mqtt_subscriber_security.log",
      "maxBytes": 104857600,
      "backupCount": 10
    }
  },
  "loggers": {
    "mqtt_subscriber": {
      "level": "INFO",
      "handlers": ["console", "file", "error_file"],
      "propagate": false
    },
    "security": {
      "level": "WARNING",
      "handlers": ["security_file", "console"],
      "propagate": false
    }
  },
  "root": {
    "level": "INFO",
    "handlers": ["console", "file"]
  }
}
