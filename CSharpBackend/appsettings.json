{
  "Urls": "http://0.0.0.0:5001",
  "ConnectionStrings": {
    "PlcGateway": "Host=localhost;Port=5432;Database=Automation_DB;Username=cereveate;Password=${DB_PASSWORD};Maximum Pool Size=30;Minimum Pool Size=5;Timeout=15;Command Timeout=60"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "OpcDaWebBrowser.Services.HistorianIngest": "Warning",
      "OpcDaWebBrowser.Services.HistorianIngest.Services.BatcherService": "Warning",
      "OpcDaWebBrowser.Services.HistorianIngest.Services.DbWriterService": "Warning",
      "OpcDaWebBrowser.Services.HistorianIngest.Services.RateControllerService": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Performance": {
    "EnableOpcDiagnostics": true,
    "EnableHistorianDebug": false,
    "EnableBatchSummaries": true,
    "BatchSummaryInterval": 100
  },
  "Historian": {
    "Database": {
      "ConnectionString": "Host=localhost;Port=5432;Database=Automation_DB;Username=cereveate;Password=${DB_PASSWORD}",
      "CommandTimeout": 30,
      "MaxRetries": 3,
      "RetryDelayMs": 1000,
      "UseConnectionPooling": true,
      "MaxPoolSize": 100,
      "MappingRefreshIntervalSeconds": 30
    },
    "Writer": {
      "WriterName": "HistorianWriter01",
      "ShardCount": 8,
      "EnableCheckpointing": true,
      "CheckpointIntervalSeconds": 30
    },
    "Spool": {
      "Enabled": true,
      "SpoolDirectory": "D:\\HistorianSpool",
      "MaxSpoolSizeMB": 10240,
      "ReplayIntervalSeconds": 60,
      "AutoReplay": true
    },
    "Batch": {
      "MaxRows": 1,
      "MaxBytes": 5242880,
      "MaxWaitMs": 500,
      "UseBinaryCopy": true
    },
    "RateControl": {
      "Enabled": true,
      "UseChangeDetection": true,
      "DefaultDeadband": 0.0,
      "MinIntervalMs": 1000,
      "MaxIntervalMs": 60000
    }
  },
  "HealthMonitor": {
    "Enabled": true,
    "ResourceSampleIntervalSeconds": 10,
    "DiskMonitoringEnabled": true
  },
  "OpcUa": {
    "AutoConnect": "",
    "DefaultPollingIntervalMs": 1000,
    "MaxReconnectAttempts": 10,
    "ReconnectDelayMs": 5000
  },
  "PlcGateway": {
    "DefaultScanRateMs": 200,
    "DefaultTransmissionIntervalMs": 1000,
    "DefaultReconnectDelayMs": 5000,
    "HistorianPollIntervalMs": 2000,
    "HistorianBatchSize": 200,
    "DefaultWriteIntervalMs": 5000,
    "Connections": [
      {
        "PlcId": "Rockwel_PLC_001",
        "PlcName": "Rockwell Production PLC",
        "PlantId": "PlantA",
        "Protocol": "Rockwell",
        "IpAddress": "192.168.0.20",
        "Port": 44818,
        "PollingIntervalMs": 1000,
        "TimeoutMs": 3000,
        "Enabled": true,
        "RockwellConfig": {
          "PlcType": "ControlLogix",
          "Path": "1,0",
          "UseConnectedMessaging": true
        },
        "Tags": [
          { "TagId": "TY1101A",  "TagName": "Temperature TY1101A",              "DataType": "double", "Unit": "C"   },
          { "TagId": "PY1101A",  "TagName": "Filter Inlet Pressure 1#",            "DataType": "float",  "Unit": "KPA" },
          { "TagId": "PY1101B",  "TagName": "Filter Inlet Pressure 2#",            "DataType": "float",  "Unit": "KPA" },
          { "TagId": "PY1103A",  "TagName": "Roots Fan Outlet Pressure #1",        "DataType": "float",  "Unit": "KPA" },
          { "TagId": "PY1103B",  "TagName": "Roots Fan Outlet Pressure #2",        "DataType": "float",  "Unit": "KPA" }
        ]
      }
    ],
    "LocalBroadcast": {
      "Enabled": true,
      "Port": 5050,
      "IntervalMs": 1000,
      "BindAddress": "0.0.0.0"
    },
    "Transport": {
      "Enabled": true,
      "PublishIntervalMs": 1000,
      "UseSampleBuffer": true
    },
    "Mqtt": {
      "Enabled": true,
      "BrokerHost": "localhost",
      "BrokerPort": 1883,
      "ClientId": "PlcGateway_Server",
      "TopicPrefix": "",
      "PublishMode": "Bulk",
      "QualityOfService": 1,
      "RetainMessages": false
    },
    "Health": {
      "Enabled": true,
      "IntervalMs": 5000,
      "PublishToMqtt": true,
      "MqttTopic": "plc/health"
    }
  },
  "OpcMqttTransport": {
    "Enabled": true,
    "BrokerHost": "127.0.0.1",
    "BrokerPort": 1883,
    "ClientId": "cereveate_central_opc",
    "Username": "",
    "Password": "",
    "TopicPrefix": "",
    "QualityOfService": 1,
    "RetainMessages": false,
    "KeepAliveSeconds": 60,
    "ReconnectDelayMs": 5000,
    "PublishMode": "ChangedOnly",
    "MaxTagsPerBatch": 500
  },
  "AlarmEvaluation": {
    "Enabled": true,
    "EvaluationIntervalMs": 1000,
    "SetpointCacheRefreshIntervalSeconds": 60,
    "RuntimeStateRefreshIntervalSeconds": 30,
    "MqttAlarmTopic": "opc/alarms/events",
    "MaxConsecutiveDbFailures": 5,
    "DbCircuitBreakerTimeoutMinutes": 2,
    "SystemActorName": "OPC_SYSTEM",
    "MqttClientIdSuffix": "alarm-eval",
    "InterlockEnabled": true,
    "MqttInterlockTopic": "opc/interlocks/events",
    "MqttInterlockClientIdSuffix": "interlock-eval"
  }
}
