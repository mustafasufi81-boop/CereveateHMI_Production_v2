@page
@{
    ViewData["Title"] = "OPC DA Browser";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            max-width: 1600px;
            margin: 0 auto;
            background: white;
            border-radius: 15px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            overflow: hidden;
        }

        .header {
            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
            color: white;
            padding: 30px;
            text-align: center;
        }

        .header h1 {
            font-size: 2.5em;
            margin-bottom: 10px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
        }

        .header p {
            font-size: 1.1em;
            opacity: 0.9;
        }

        .controls {
            padding: 25px;
            background: #f8f9fa;
            border-bottom: 2px solid #e0e0e0;
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            align-items: center;
        }

        .control-group {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        label {
            font-weight: 600;
            color: #333;
        }

        select, button {
            padding: 12px 20px;
            font-size: 1em;
            border: 2px solid #ddd;
            border-radius: 8px;
            transition: all 0.3s ease;
        }

        select {
            min-width: 250px;
            background: white;
        }

        select:hover {
            border-color: #667eea;
        }

        button {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            cursor: pointer;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        button:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
        }

        button:disabled {
            background: #ccc;
            cursor: not-allowed;
            transform: none;
        }

        .status {
            flex: 1;
            text-align: right;
            padding: 12px 20px;
            border-radius: 8px;
            font-weight: 600;
        }

        .status.connected {
            background: #d4edda;
            color: #155724;
        }

        .status.disconnected {
            background: #f8d7da;
            color: #721c24;
        }

        .status.loading {
            background: #fff3cd;
            color: #856404;
        }

        .content {
            display: flex;
            gap: 20px;
            padding: 25px;
            min-height: 600px;
        }

        .left-panel {
            flex: 0 0 400px;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .right-panel {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .panel {
            background: white;
            border: 2px solid #e0e0e0;
            border-radius: 10px;
            overflow: hidden;
        }

        .panel-header {
            background: linear-gradient(135deg, #434343 0%, #000000 100%);
            color: white;
            padding: 15px 20px;
            font-weight: 600;
            font-size: 1.1em;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .panel-body {
            padding: 20px;
            max-height: 600px;
            overflow-y: auto;
        }

        .tag-tree {
            list-style: none;
        }

        .tag-item {
            padding: 10px;
            margin: 5px 0;
            border-radius: 5px;
            cursor: pointer;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .tag-item:hover {
            background: #f0f0f0;
        }

        .tag-item.folder {
            font-weight: 600;
            color: #2a5298;
        }

        .tag-item.leaf {
            color: #333;
        }

        .tag-item input[type="checkbox"] {
            width: 20px;
            height: 20px;
            cursor: pointer;
        }

        .tag-icon {
            width: 20px;
            text-align: center;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th {
            background: #f8f9fa;
            padding: 15px;
            text-align: left;
            font-weight: 600;
            color: #333;
            border-bottom: 2px solid #dee2e6;
            position: sticky;
            top: 0;
        }

        td {
            padding: 12px 15px;
            border-bottom: 1px solid #e0e0e0;
        }

        tr:hover {
            background: #f8f9fa;
        }

        .quality-good {
            background: #d4edda;
            color: #155724;
            padding: 5px 12px;
            border-radius: 20px;
            font-weight: 600;
            display: inline-block;
        }

        .quality-uncertain {
            background: #fff3cd;
            color: #856404;
            padding: 5px 12px;
            border-radius: 20px;
            font-weight: 600;
            display: inline-block;
        }

        .quality-bad {
            background: #f8d7da;
            color: #721c24;
            padding: 5px 12px;
            border-radius: 20px;
            font-weight: 600;
            display: inline-block;
        }

        .remove-btn {
            background: #dc3545;
            color: white;
            border: none;
            padding: 5px 15px;
            border-radius: 5px;
            cursor: pointer;
            font-size: 0.9em;
        }

        .remove-btn:hover {
            background: #c82333;
        }

        .trend-btn {
            background: #007bff;
            color: white;
            border: none;
            padding: 5px 15px;
            border-radius: 5px;
            cursor: pointer;
            font-size: 0.9em;
        }

        .trend-btn:hover {
            background: #0056b3;
        }

        .modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.7);
        }

        .modal-content {
            background: white;
            margin: 5% auto;
            padding: 0;
            border-radius: 10px;
            width: 90%;
            max-width: 1200px;
            max-height: 80vh;
            overflow: hidden;
            box-shadow: 0 5px 30px rgba(0,0,0,0.5);
        }

        .modal-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .modal-header h2 {
            margin: 0;
            font-size: 1.5em;
        }

        .close-modal {
            background: rgba(255,255,255,0.2);
            border: none;
            color: white;
            font-size: 2em;
            cursor: pointer;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .close-modal:hover {
            background: rgba(255,255,255,0.3);
        }

        .modal-body {
            padding: 20px;
            max-height: calc(80vh - 80px);
            overflow-y: auto;
        }

        .trend-controls {
            display: flex;
            gap: 15px;
            margin-bottom: 20px;
            align-items: center;
        }

        .trend-controls label {
            font-weight: 600;
        }

        .trend-controls select {
            padding: 8px;
            border-radius: 5px;
            border: 1px solid #ddd;
        }

        #trendChart {
            width: 100%;
            height: 400px;
            border: 1px solid #ddd;
            border-radius: 5px;
            padding: 20px;
            background: #f8f9fa;
        }

        .trend-stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
            margin-top: 20px;
        }

        .stat-card {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 15px;
            border-radius: 8px;
            text-align: center;
        }

        .stat-card .stat-label {
            font-size: 0.9em;
            opacity: 0.9;
            margin-bottom: 5px;
        }

        .stat-card .stat-value {
            font-size: 1.5em;
            font-weight: 600;
        }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: #999;
        }

        .empty-state svg {
            width: 100px;
            height: 100px;
            margin-bottom: 20px;
            opacity: 0.3;
        }

        .loader {
            border: 4px solid #f3f3f3;
            border-top: 4px solid #667eea;
            border-radius: 50%;
            width: 40px;
            height: 40px;
            animation: spin 1s linear infinite;
            margin: 20px auto;
        }

        @@keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .client-count {
            background: rgba(255,255,255,0.2);
            padding: 5px 15px;
            border-radius: 20px;
            font-size: 0.9em;
        }

        @@media (max-width: 1200px) {
            .content {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>🌐 OPC DA Web Browser</h1>
            <p>Real-time OPC Data Monitoring from Any Device</p>
        </div>

        <div class="controls" style="padding: 25px;">
            <!-- Local Servers Section -->
            <div class="server-section" style="margin-bottom: 20px; border: 2px solid #4CAF50; border-radius: 8px; padding: 15px; background: rgba(76, 175, 80, 0.05);">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
                    <h3 style="margin: 0; color: #4CAF50;">💻 Local OPC Servers</h3>
                    <button onclick="discoverLocalServers()" style="padding: 8px 16px; background: #4CAF50; color: white; border: none; border-radius: 5px; cursor: pointer; font-size: 0.9em;">🔍 Discover</button>
                </div>
                <div id="localServersList" style="max-height: 200px; overflow-y: auto;"></div>
            </div>

            <!-- Remote Servers Section -->
            <div class="server-section" style="margin-bottom: 20px; border: 2px solid #2196F3; border-radius: 8px; padding: 15px; background: rgba(33, 150, 243, 0.05);">
                <h3 style="margin: 0 0 10px 0; color: #2196F3;">🌐 Remote OPC Servers</h3>
                <div style="display: flex; gap: 10px; margin-bottom: 15px;">
                    <input type="text" id="remoteHost" placeholder="IP: 172.16.160.16" style="flex: 1; padding: 10px; border: 2px solid #ddd; border-radius: 5px;">
                    <button onclick="discoverRemoteServers()" style="padding: 10px 20px; background: #2196F3; color: white; border: none; border-radius: 5px; cursor: pointer;">🔍 Discover</button>
                </div>
                <div id="remoteServersList" style="max-height: 200px; overflow-y: auto;"></div>
            </div>

            <!-- Active Connections -->
            <div style="border: 2px solid #9C27B0; border-radius: 8px; padding: 15px; background: rgba(156, 39, 176, 0.05);">
                <h3 style="margin: 0 0 10px 0; color: #9C27B0;">🔗 Active Connections</h3>
                <div id="connectedServersList" style="display: flex; flex-wrap: wrap; gap: 10px; min-height: 50px;"></div>
            </div>
        </div>

        <div id="statusLabel" class="status disconnected" style="margin: 20px 0;">
            ⚫ Initializing...
        </div>

        <div class="content">
            <div class="left-panel">
                <div class="panel">
                    <div class="panel-header">
                        📁 Available Tags
                        <span class="client-count" id="tagCount">0 tags</span>
                    </div>
                    <div class="panel-body">
                        <div id="tagTree"></div>
                    </div>
                </div>
            </div>

            <div class="right-panel">
                <div class="panel" style="flex: 1;">
                    <div class="panel-header">
                        📊 Live Tag Values
                        <span class="client-count" id="clientCount">👥 0 clients</span>
                    </div>
                    <div class="panel-body">
                        <table id="tagValuesTable" style="display: none;">
                            <thead>
                                <tr>
                                    <th>Tag Name</th>
                                    <th>Value</th>
                                    <th>Data Type</th>
                                    <th>Quality</th>
                                    <th>Timestamp</th>
                                    <th>Trend</th>
                                    <th>Remove</th>
                                </tr>
                            </thead>
                            <tbody id="tagValuesBody"></tbody>
                        </table>
                        <div id="emptyState" class="empty-state">
                            <p style="font-size: 1.2em; color: #999;">📊 No tags monitored</p>
                            <p style="margin-top: 10px;">Connect to a server and check tags from the left panel</p>
                        </div>
                    </div>
                </div>

                <div class="panel" id="trendPanel" style="display: none; flex: 1;">
                    <div class="panel-header">
                        📈 Trend Chart: <span id="currentTrendTag">-</span>
                        <button onclick="closeTrend()" style="background: rgba(255,255,255,0.2); border: none; color: white; padding: 5px 15px; border-radius: 5px; cursor: pointer;">✕ Close</button>
                    </div>
                    <div class="panel-body">
                        <div class="trend-controls">
                            <label>Time Range:</label>
                            <select id="trendHours" onchange="refreshTrend()">
                                <option value="1">Last 1 Hour</option>
                                <option value="2">Last 2 Hours</option>
                                <option value="4">Last 4 Hours</option>
                                <option value="8">Last 8 Hours</option>
                                <option value="24">Last 24 Hours</option>
                            </select>
                        </div>
                        <canvas id="trendChart" style="width: 100%; height: 300px;"></canvas>
                        <div class="trend-stats" id="trendStats"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.0/signalr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        console.log("Script started");
        console.log("signalR available:", typeof signalR !== 'undefined');
        
        // SignalR connection setup
        let connection = new signalR.HubConnectionBuilder()
            .withUrl("/opcHub")
            .withAutomaticReconnect()
            .configureLogging(signalR.LogLevel.Information)
            .build();

        let connections = {}; // connectionId -> { progId, host, status, tags }
        let monitoredTags = {}; // itemId -> { connectionId, tagInfo }
        let currentTrendTag = '';
        let currentTrendName = '';

        // SignalR event handlers
        connection.on("TagValuesUpdated", (values) => {
            console.log("📊 Received tag values:", values);
            updateTagValues(values);
        });

        connection.on("ServerConnected", (connectionId) => {
            console.log(`✅ Server connected: ${connectionId}`);
            refreshConnections();
        });

        connection.on("ServerDisconnected", (connectionId) => {
            console.log(`⚠️ Server disconnected: ${connectionId}`);
            refreshConnections();
        });

        // Start SignalR connection
        connection.start()
            .then(() => {
                console.log("✅ SignalR connected");
                updateStatus("✅ Ready - Click Discover to find OPC servers", "disconnected");
                refreshConnections();
            })
            .catch(err => {
                console.error("❌ SignalR error:", err);
                updateStatus("❌ Connection failed: " + err.message, "disconnected");
            });

        // Discover local servers
        async function discoverLocalServers() {
            try {
                updateStatus("🔍 Discovering local OPC servers...", "loading");
                const servers = await connection.invoke("DiscoverServers");
                
                const list = document.getElementById("localServersList");
                if (!servers || servers.length === 0) {
                    list.innerHTML = '<div style="padding: 10px; color: #999;">No local OPC servers found</div>';
                    updateStatus("⚠️ No local servers found", "disconnected");
                    return;
                }
                
                list.innerHTML = servers.map(server => `
                    <div style="display: flex; justify-content: space-between; align-items: center; padding: 8px; border-bottom: 1px solid #eee;">
                        <span style="font-size: 0.9em;">${server}</span>
                        <button onclick="addLocalServer('${server}')" style="padding: 5px 15px; background: #4CAF50; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 0.85em;">➕ Add</button>
                    </div>
                `).join('');
                
                updateStatus(`✅ Found ${servers.length} local server(s)`, "disconnected");
            } catch (err) {
                console.error("Discovery error:", err);
                updateStatus("❌ Discovery failed: " + err.message, "disconnected");
            }
        }

        // Discover remote servers
        async function discoverRemoteServers() {
            const host = document.getElementById("remoteHost").value.trim();
            if (!host) {
                alert("Please enter IP address (e.g., 172.16.160.16)");
                return;
            }
            
            try {
                updateStatus(`🔍 Discovering servers on ${host}...`, "loading");
                const servers = await connection.invoke("DiscoverRemoteServers", host);
                
                const list = document.getElementById("remoteServersList");
                if (!servers || servers.length === 0) {
                    list.innerHTML = `<div style="padding: 10px; color: #999;">No servers found on ${host}</div>`;
                    updateStatus(`⚠️ No servers on ${host}`, "disconnected");
                    return;
                }
                
                list.innerHTML = servers.map(server => `
                    <div style="display: flex; justify-content: space-between; align-items: center; padding: 8px; border-bottom: 1px solid #eee;">
                        <div style="flex: 1;">
                            <div style="font-size: 0.9em; font-weight: 600;">${server.progID}</div>
                            <div style="font-size: 0.75em; color: #666;">${server.description}</div>
                        </div>
                        <button onclick="addRemoteServer('${server.progID}', '${host}')" style="padding: 5px 15px; background: #2196F3; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 0.85em;">➕ Add</button>
                    </div>
                `).join('');
                
                updateStatus(`✅ Found ${servers.length} server(s) on ${host}`, "disconnected");
            } catch (err) {
                console.error("Remote discovery error:", err);
                updateStatus(`❌ Discovery failed on ${host}: ${err.message}`, "disconnected");
            }
        }

        // Add local server
        async function addLocalServer(progId) {
            try {
                updateStatus(`⏳ Adding ${progId}...`, "loading");
                const connectionId = await connection.invoke("AddServerConnection", progId, "", 1000);
                await connection.invoke("ConnectServer", connectionId);
                updateStatus(`✅ Connected to ${progId}`, "connected");
                await refreshConnections();
            } catch (err) {
                console.error("Add local server error:", err);
                updateStatus(`❌ Failed to add ${progId}: ${err.message}`, "disconnected");
            }
        }

        // Add remote server
        async function addRemoteServer(progId, host) {
            try {
                updateStatus(`⏳ Adding ${progId} @@ ${host}...`, "loading");
                const connectionId = await connection.invoke("AddServerConnection", progId, host, 1000);
                await connection.invoke("ConnectServer", connectionId);
                updateStatus(`✅ Connected to ${progId} @@ ${host}`, "connected");
                await refreshConnections();
            } catch (err) {
                console.error("Add remote server error:", err);
                updateStatus(`❌ Failed to add ${progId}: ${err.message}`, "disconnected");
            }
        }

        // Refresh connections display
        async function refreshConnections() {
            try {
                const serverConnections = await connection.invoke("GetAllConnections");
                connections = {};
                
                const list = document.getElementById("connectedServersList");
                if (!serverConnections || serverConnections.length === 0) {
                    list.innerHTML = '<div style="padding: 10px; color: #999; width: 100%;">No active connections</div>';
                    return;
                }
                
                list.innerHTML = serverConnections.map(conn => {
                    connections[conn.connectionId] = conn;
                    const displayName = conn.host ? `${conn.serverProgID} @@ ${conn.host}` : conn.serverProgID;
                    const statusIcon = conn.isConnected ? '🟢' : '🔴';
                    const statusColor = conn.isConnected ? '#4CAF50' : '#f44336';
                    
                    return `
                        <div style="border: 2px solid ${statusColor}; border-radius: 6px; padding: 10px; background: white; min-width: 250px;">
                            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                                <div style="font-weight: 600; font-size: 0.9em;">${statusIcon} ${displayName}</div>
                            </div>
                            <div style="display: flex; gap: 5px;">
                                ${conn.isConnected ? 
                                    `<button onclick="browseServerTags('${conn.connectionId}')" style="flex: 1; padding: 5px; background: #2196F3; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 0.8em;">📁 Browse</button>
                                     <button onclick="disconnectServer('${conn.connectionId}')" style="flex: 1; padding: 5px; background: #FF9800; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 0.8em;">⏸️ Pause</button>` :
                                    `<button onclick="reconnectServer('${conn.connectionId}')" style="flex: 1; padding: 5px; background: #4CAF50; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 0.8em;">▶️ Connect</button>`
                                }
                                <button onclick="removeServer('${conn.connectionId}')" style="flex: 1; padding: 5px; background: #f44336; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 0.8em;">🗑️ Remove</button>
                            </div>
                        </div>
                    `;
                }).join('');
            } catch (err) {
                console.error("Refresh connections error:", err);
            }
        }

        // Server control functions
        async function disconnectServer(connectionId) {
            try {
                await connection.invoke("DisconnectServer", connectionId);
                updateStatus(`⏸️ Disconnected ${connectionId}`, "disconnected");
                await refreshConnections();
            } catch (err) {
                console.error("Disconnect error:", err);
            }
        }

        async function reconnectServer(connectionId) {
            try {
                await connection.invoke("ConnectServer", connectionId);
                updateStatus(`✅ Reconnected ${connectionId}`, "connected");
                await refreshConnections();
            } catch (err) {
                console.error("Reconnect error:", err);
            }
        }

        async function removeServer(connectionId) {
            if (!confirm(`Remove server ${connectionId}?`)) return;
            
            try {
                await connection.invoke("RemoveServerConnection", connectionId);
                updateStatus(`🗑️ Removed ${connectionId}`, "disconnected");
                await refreshConnections();
                // Clear tags from this server
                Object.keys(monitoredTags).forEach(itemId => {
                    if (monitoredTags[itemId].connectionId === connectionId) {
                        delete monitoredTags[itemId];
                    }
                });
                displayMonitoredTags();
            } catch (err) {
                console.error("Remove error:", err);
            }
        }

        // Browse tags from specific server
        async function browseServerTags(connectionId) {
            try {
                updateStatus(`🔍 Browsing tags from ${connectionId}...`, "loading");
                const tags = await connection.invoke("BrowseTags", connectionId);
                displayTagTree(tags, connectionId);
                updateStatus(`✅ Found ${tags.length} tags`, "connected");
            } catch (err) {
                console.error("Browse error:", err);
                updateStatus(`❌ Browse failed: ${err.message}`, "disconnected");
            }
        }

        // Display tag tree
        function displayTagTree(tags, connectionId) {
            const tree = document.getElementById("tagTree");
            if (!tags || tags.length === 0) {
                tree.innerHTML = '<div class="empty-state"><p>No tags available</p></div>';
                return;
            }

            const serverName = connections[connectionId] ? 
                (connections[connectionId].host ? 
                    `${connections[connectionId].serverProgID} @@ ${connections[connectionId].host}` : 
                    connections[connectionId].serverProgID) : 
                connectionId;

            tree.innerHTML = `
                <div style="padding: 10px; background: #f0f0f0; font-weight: 600; margin-bottom: 10px; border-radius: 4px;">
                    ${serverName} (${tags.length} tags)
                </div>
                ${tags.map(tag => `
                    <div class="tag-item" onclick="addTagToMonitor('${connectionId}', '${tag.itemID}', '${tag.displayName || tag.itemID}')">
                        <span class="tag-name">${tag.displayName || tag.itemID}</span>
                        <span class="tag-type">${tag.dataType || 'Unknown'}</span>
                    </div>
                `).join('')}
            `;
            
            document.getElementById("tagCount").textContent = `${tags.length} tags`;
        }

        // Add tag to monitoring
        async function addTagToMonitor(connectionId, itemId, displayName) {
            try {
                await connection.invoke("AddTagToMonitorWithConnection", connectionId, itemId, displayName);
                monitoredTags[itemId] = { connectionId, itemId, displayName };
                displayMonitoredTags();
                updateStatus(`✅ Monitoring ${displayName}`, "connected");
            } catch (err) {
                console.error("Add tag error:", err);
                updateStatus(`❌ Failed to add tag: ${err.message}`, "disconnected");
            }
        }

        // Remove tag from monitoring
        async function removeTagFromMonitor(connectionId, itemId) {
            try {
                await connection.invoke("RemoveTagFromMonitorWithConnection", connectionId, itemId);
                delete monitoredTags[itemId];
                displayMonitoredTags();
                updateStatus(`🗑️ Removed tag ${itemId}`, "connected");
            } catch (err) {
                console.error("Remove tag error:", err);
            }
        }

        // Display monitored tags
        function displayMonitoredTags() {
            const container = document.getElementById("valueCards");
            const tags = Object.values(monitoredTags);
            
            if (tags.length === 0) {
                container.innerHTML = '<div class="empty-state"><p>No tags being monitored. Browse tags and click to add.</p></div>';
                return;
            }

            container.innerHTML = tags.map(tag => {
                const serverName = connections[tag.connectionId] ? 
                    (connections[tag.connectionId].host ? 
                        `${connections[tag.connectionId].serverProgID} @@ ${connections[tag.connectionId].host}` : 
                        connections[tag.connectionId].serverProgID) : 
                    tag.connectionId;
                
                return `
                    <div class="value-card" id="card-${tag.itemId}">
                        <div class="card-header">
                            <span class="card-title">${tag.displayName}</span>
                            <button class="remove-btn" onclick="removeTagFromMonitor('${tag.connectionId}', '${tag.itemId}')">✕</button>
                        </div>
                        <div class="card-value" id="value-${tag.itemId}">--</div>
                        <div class="card-footer">
                            <span id="quality-${tag.itemId}" style="font-size: 0.75em; color: #999;">Waiting...</span>
                            <span style="font-size: 0.75em; color: #666;">${serverName}</span>
                        </div>
                    </div>
                `;
            }).join('');
        }

        // Update tag values
        function updateTagValues(values) {
            if (!Array.isArray(values)) return;
            
            values.forEach(tag => {
                const valueEl = document.getElementById(`value-${tag.itemID}`);
                const qualityEl = document.getElementById(`quality-${tag.itemID}`);
                
                if (valueEl) {
                    valueEl.textContent = tag.value !== null && tag.value !== undefined ? tag.value : '--';
                }
                if (qualityEl) {
                    const qualityText = tag.quality || 'Unknown';
                    const qualityColor = qualityText.includes('GOOD') || qualityText.includes('Good') ? '#4CAF50' : '#f44336';
                    qualityEl.textContent = qualityText;
                    qualityEl.style.color = qualityColor;
                }
            });
        }

        function updateStatus(message, status) {
            const label = document.getElementById("statusLabel");
            label.textContent = message;
            label.className = `status ${status}`;
        }

        // Trend functionality
        async function viewTrend(itemID, displayName) {
                
                const select = document.getElementById("serverSelect");
                select.innerHTML = "";
                
                if (!servers || servers.length === 0) {
                    select.innerHTML = "<option>No OPC servers found locally</option>";
                    updateStatus("⚠️ No local OPC servers found - Try entering remote IP", "disconnected");
                    console.warn("⚠️ No servers discovered");
                } else {
                    servers.forEach(server => {
                        const option = document.createElement("option");
                        option.value = server;
                        option.textContent = server;
                        option.dataset.host = "";
                        select.appendChild(option);
                    });
                    select.disabled = false;
                    document.getElementById("connectBtn").disabled = false;
                    updateStatus(`✅ Found ${servers.length} local server(s) - Select to connect`, "disconnected");
                    console.log(`✅ Loaded ${servers.length} servers successfully`);
                }
            } catch (err) {
                console.error("❌ SignalR discovery error:", err);
                updateStatus("⚠️ SignalR error - Trying REST API...", "loading");
                loadServersViaREST();
            }
        }

        // Fallback: Load servers via REST API
        async function loadServersViaREST() {
            try {
                console.log("🔍 Calling /api/opc/servers via REST...");
                const response = await fetch('/api/opc/servers');
                if (!response.ok) throw new Error(`HTTP ${response.status}`);
                
                const servers = await response.json();
                console.log("📡 REST API returned:", servers);
                
                const select = document.getElementById("serverSelect");
                select.innerHTML = "";
                
                if (!servers || servers.length === 0) {
                    select.innerHTML = "<option>No OPC servers found</option>";
                    updateStatus("⚠️ No servers found", "disconnected");
                } else {
                    servers.forEach(server => {
                        const option = document.createElement("option");
                        option.value = server;
                        option.textContent = server;
                        option.dataset.host = "";
                        select.appendChild(option);
                    });
                    select.disabled = false;
                    document.getElementById("connectBtn").disabled = false;
                    updateStatus(`✅ Found ${servers.length} server(s) via REST`, "disconnected");
                }
            } catch (err) {
                console.error("❌ REST API error:", err);
                updateStatus("❌ Failed to discover servers", "disconnected");
            }
        }

        // Discover button - handles both local and remote
        document.getElementById("discoverRemoteBtn").addEventListener("click", async () => {
            const hostInput = document.getElementById("remoteHost");
            const host = hostInput.value.trim();
            
            if (!host) {
                // Empty = discover local servers
                console.log("🔍 Discovering LOCAL servers...");
                updateStatus("🔍 Discovering local OPC servers...", "loading");
                await loadServers();
                return;
            }
            
            // Has IP = discover remote servers
            try {
                console.log(`🔍 Discovering REMOTE servers on ${host}...`);
                updateStatus(`🔍 Discovering servers on ${host}...`, "loading");
                const servers = await connection.invoke("DiscoverRemoteServers", host);
                console.log(`📡 Remote discovery returned:`, servers);
                
                const select = document.getElementById("serverSelect");
                select.innerHTML = "";
                
                if (!servers || servers.length === 0) {
                    select.innerHTML = `<option>No OPC servers found on ${host}</option>`;
                    updateStatus(`⚠️ No servers found on ${host}`, "disconnected");
                } else {
                    servers.forEach(server => {
                        const option = document.createElement("option");
                        option.value = server.progID;
                        option.textContent = `${server.progID} - ${server.description}`;
                        option.dataset.host = host;
                        select.appendChild(option);
                    });
                    select.disabled = false;
                    document.getElementById("connectBtn").disabled = false;
                    updateStatus(`✅ Found ${servers.length} server(s) on ${host} - Select to connect`, "disconnected");
                }
            } catch (err) {
                console.error("❌ Remote discovery error:", err);
                updateStatus(`❌ Discovery failed on ${host}: ${err.message}`, "disconnected");
            }
        });

        // Connect to server
        document.getElementById("connectBtn").addEventListener("click", async () => {
            const mode = document.getElementById("connectionMode").value;
            let serverName, host;
            
            if (mode === "manual") {
                // Manual mode: use manual server name + remote IP
                serverName = document.getElementById("manualServerName").value.trim();
                host = document.getElementById("remoteHost").value.trim();
                
                if (!serverName) {
                    alert("Please enter OPC Server ProgID (e.g., MCS.OPCServer.1)");
                    return;
                }
                if (!host) {
                    alert("Please enter remote IP address");
                    return;
                }
            } else {
                // Local or Remote discovery mode: use selected server from dropdown
                const serverSelect = document.getElementById("serverSelect");
                const selectedOption = serverSelect.options[serverSelect.selectedIndex];
                serverName = serverSelect.value;
                host = selectedOption.dataset.host || "";
                
                if (!serverName) return;
            }
            
            try {
                const displayName = host ? (serverName + " @@ " + host) : serverName;
                updateStatus("⏳ Connecting to " + displayName + "...", "loading");
                
                if (host) {
                    await connection.invoke("ConnectToRemoteServer", serverName, host);
                } else {
                    await connection.invoke("ConnectToServer", serverName, host);
                }
                
                document.getElementById("connectBtn").disabled = true;
                document.getElementById("disconnectBtn").disabled = false;
                document.getElementById("browseBtn").disabled = false;
                document.getElementById("connectionMode").disabled = true;
                document.getElementById("serverSelect").disabled = true;
                document.getElementById("remoteHost").disabled = true;
                document.getElementById("manualServerName").disabled = true;
                document.getElementById("discoverRemoteBtn").disabled = true;
                
                updateStatus("✅ Connected to " + displayName, "connected");
            } catch (err) {
                console.error("Connection error:", err);
                updateStatus(`❌ Failed to connect: ${err.message}`, "disconnected");
            }
        });

        // Disconnect from server
        document.getElementById("disconnectBtn").addEventListener("click", async () => {
            try {
                await connection.invoke("DisconnectFromServer");
                
                document.getElementById("connectBtn").disabled = false;
                document.getElementById("disconnectBtn").disabled = true;
                document.getElementById("browseBtn").disabled = true;
                document.getElementById("connectionMode").disabled = false;
                document.getElementById("serverSelect").disabled = false;
                document.getElementById("remoteHost").disabled = false;
                document.getElementById("manualServerName").disabled = false;
                document.getElementById("discoverRemoteBtn").disabled = false;
                
                document.getElementById("tagTree").innerHTML = "";
                document.getElementById("tagValuesBody").innerHTML = "";
                
                currentRemoteHost = "";
                updateStatus("⚫ Disconnected", "disconnected");
            } catch (err) {
                console.error("Disconnect error:", err);
            }
        });

        // Browse tags
        document.getElementById("browseBtn").addEventListener("click", async () => {
            try {
                updateStatus("🔍 Browsing tags...", "loading");
                const tags = await connection.invoke("BrowseTags");
                
                displayTags(tags);
                document.getElementById("tagCount").textContent = `${tags.length} tags`;
                
                const serverName = document.getElementById("serverSelect").value;
                updateStatus(`✅ Connected to ${serverName} - ${tags.length} tag(s)`, "connected");
            } catch (err) {
                console.error("Browse error:", err);
                updateStatus(`❌ Browse failed: ${err.message}`, "connected");
            }
        });

        // Display tags
        function displayTags(tags) {
            const container = document.getElementById("tagTree");
            
            if (tags.length === 0) {
                container.innerHTML = '<div class="empty-state">📂 No tags found</div>';
                return;
            }
            
            let html = '<ul class="tag-tree">';
            
            tags.forEach(tag => {
                const icon = tag.isFolder ? '📁' : '🏷️';
                const className = tag.isFolder ? 'folder' : 'leaf';
                const dataType = tag.dataType ? ` <span style="color: #999; font-size: 0.9em;">(${tag.dataType})</span>` : '';
                
                html += `
                    <li class="tag-item ${className}">
                        <input type="checkbox" 
                               data-itemid="${tag.itemID}" 
                               data-name="${tag.name}"
                               ${tag.isFolder ? 'disabled' : ''}
                               onchange="toggleTagMonitoring(this)">
                        <span class="tag-icon">${icon}</span>
                        <span>${tag.name}${dataType}</span>
                    </li>
                `;
            });
            
            html += '</ul>';
            container.innerHTML = html;
        }

        // Toggle tag monitoring
        async function toggleTagMonitoring(checkbox) {
            const itemID = checkbox.dataset.itemid;
            const name = checkbox.dataset.name;
            
            try {
                if (checkbox.checked) {
                    await connection.invoke("AddTagToMonitor", itemID, name);
                } else {
                    await connection.invoke("RemoveTagFromMonitor", itemID);
                }
            } catch (err) {
                console.error("Error toggling tag:", err);
                checkbox.checked = !checkbox.checked;
            }
        }

        // Receive tag values
        connection.on("ReceiveTagValues", (values) => {
            displayTagValues(values);
        });

        // Display tag values in table
        function displayTagValues(values) {
            const tbody = document.getElementById("tagValuesBody");
            const table = document.getElementById("tagValuesTable");
            const emptyState = document.getElementById("emptyState");
            
            if (values.length === 0) {
                table.style.display = 'none';
                emptyState.style.display = 'block';
                return;
            }
            
            table.style.display = 'table';
            emptyState.style.display = 'none';
            
            tbody.innerHTML = '';
            
            values.forEach(tag => {
                const qualityClass = tag.quality === 'GOOD' ? 'quality-good' : 
                                   tag.quality === 'UNCERTAIN' ? 'quality-uncertain' : 'quality-bad';
                const timestamp = new Date(tag.timestamp).toLocaleString();
                
                const row = document.createElement('tr');
                row.innerHTML = `
                    <td><strong>${tag.displayName}</strong></td>
                    <td style="font-size: 1.1em; font-weight: 600; color: #2a5298;">${tag.value}</td>
                    <td><small style="color: #666;">${tag.dataType || 'N/A'}</small></td>
                    <td><span class="${qualityClass}">${tag.quality}</span></td>
                    <td><small>${timestamp}</small></td>
                    <td>
                        <button onclick="showTrend('${tag.itemID}', '${tag.displayName}')" 
                                style="padding: 5px 15px; font-size: 0.9em; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none; border-radius: 5px; cursor: pointer;">
                            📈 View
                        </button>
                    </td>
                    <td>
                        <button onclick="removeTag('${tag.itemID}')"
                                style="padding: 5px 15px; font-size: 0.9em; background: #dc3545; color: white; border: none; border-radius: 5px; cursor: pointer;">
                            ✕
                        </button>
                    </td>
                `;
                tbody.appendChild(row);
            });
        }

        // Remove tag from monitoring
        async function removeTag(itemID) {
            try {
                await connection.invoke("RemoveTagFromMonitor", itemID);
                // Uncheck the checkbox in tag tree
                const checkbox = document.querySelector(`input[data-itemid="${itemID}"]`);
                if (checkbox) checkbox.checked = false;
            } catch (err) {
                console.error("Error removing tag:", err);
            }
        }

        // Show trend inline
        let currentTrendChart = null;
        async function showTrend(itemID, displayName) {
            const trendPanel = document.getElementById("trendPanel");
            const currentTag = document.getElementById("currentTrendTag");
            
            trendPanel.style.display = 'block';
            currentTag.textContent = displayName;
            currentTrendTag = itemID;
            currentTrendName = displayName;
            
            await refreshTrend();
        }

        // Close trend
        function closeTrend() {
            document.getElementById("trendPanel").style.display = 'none';
            if (currentTrendChart) {
                currentTrendChart.destroy();
                currentTrendChart = null;
            }
        }

        // Refresh trend data
        async function refreshTrend() {
            if (!currentTrendTag) return;
            
            const hours = document.getElementById("trendHours").value;
            
            try {
                const response = await fetch(`/api/opc/trend/${encodeURIComponent(currentTrendTag)}?hours=${hours}`);
                const data = await response.json();
                
                // Draw chart
                const ctx = document.getElementById("trendChart").getContext("2d");
                
                if (currentTrendChart) {
                    currentTrendChart.destroy();
                }
                
                currentTrendChart = new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: data.data.map(d => new Date(d.timestamp).toLocaleTimeString()),
                        datasets: [{
                            label: currentTrendName,
                            data: data.data.map(d => d.value),
                            borderColor: '#667eea',
                            backgroundColor: 'rgba(102, 126, 234, 0.1)',
                            tension: 0.4,
                            fill: true
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                display: true
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: false
                            }
                        }
                    }
                });
                
                // Show statistics
                const statsResponse = await fetch(`/api/opc/trend-stats/${encodeURIComponent(currentTrendTag)}?hours=${hours}`);
                const stats = await statsResponse.json();
                
                const statsHtml = `
                    <div class="stat-card">
                        <div class="stat-label">Min Value</div>
                        <div class="stat-value">${stats.minValue.toFixed(2)}</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label">Max Value</div>
                        <div class="stat-value">${stats.maxValue.toFixed(2)}</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label">Average</div>
                        <div class="stat-value">${stats.avgValue.toFixed(2)}</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label">Data Points</div>
                        <div class="stat-value">${stats.count}</div>
                    </div>
                `;
                document.getElementById("trendStats").innerHTML = statsHtml;
                
            } catch (err) {
                console.error("Error loading trend:", err);
            }
        }
                        <td>
                            <button class="trend-btn" onclick="viewTrend('${tag.itemID}', '${tag.displayName}')">📈 View</button>
                        </td>
                        <td>
                            <button class="remove-btn" onclick="removeTag('${tag.itemID}')">Remove</button>
                        </td>
                    </tr>
                `;
            });
            
            html += '</tbody></table>';
            container.innerHTML = html;
        }

        // Remove tag
        async function removeTag(itemID) {
            try {
                await connection.invoke("RemoveTagFromMonitor", itemID);
                
                // Uncheck the checkbox
                const checkbox = document.querySelector(`input[data-itemid="${itemID}"]`);
                if (checkbox) checkbox.checked = false;
            } catch (err) {
                console.error("Error removing tag:", err);
            }
        }

        // Update status
        function updateStatus(message, state) {
            const label = document.getElementById("statusLabel");
            label.textContent = message;
            label.className = `status ${state}`;
        }

        // Connection events
        connection.on("ServerConnected", (serverName) => {
            console.log("Server connected:", serverName);
        });

        connection.on("ServerDisconnected", () => {
            console.log("Server disconnected");
        });

        connection.on("TagAdded", (itemID, displayName) => {
            console.log("Tag added:", displayName);
        });

        connection.on("TagRemoved", (itemID) => {
            console.log("Tag removed:", itemID);
        });

        // Simulate client count (in production, track on server)
        setInterval(() => {
            connectedClients = Math.floor(Math.random() * 3) + 1;
            document.getElementById("clientCount").textContent = `👥 ${connectedClients} client${connectedClients > 1 ? 's' : ''}`;
        }, 5000);

        // Trend functionality
        async function viewTrend(itemID, displayName) {
            currentTrendTag = itemID;
            currentTrendName = displayName;
            
            document.getElementById('trendTitle').textContent = `📈 Trend: ${displayName}`;
            document.getElementById('trendModal').style.display = 'block';
            
            await refreshTrend();
        }

        function closeTrendModal() {
            document.getElementById('trendModal').style.display = 'none';
            if (trendChart) {
                trendChart.destroy();
                trendChart = null;
            }
        }

        async function refreshTrend() {
            try {
                const hours = document.getElementById('trendRange').value;
                
                // Fetch trend data
                const response = await fetch(`/api/opc/trend/${encodeURIComponent(currentTrendTag)}?hours=${hours}`);
                const data = await response.json();
                
                if (data.success && data.dataPoints && data.dataPoints.length > 0) {
                    displayTrendChart(data.dataPoints);
                    await loadTrendStats(hours);
                } else {
                    document.getElementById('trendChart').innerHTML = 
                        '<p style="text-align: center; padding: 50px; color: #999;">No trend data available for this tag yet.</p>';
                }
            } catch (err) {
                console.error('Error loading trend data:', err);
                document.getElementById('trendChart').innerHTML = 
                    '<p style="text-align: center; padding: 50px; color: red;">Error loading trend data</p>';
            }
        }

        function displayTrendChart(dataPoints) {
            const ctx = document.createElement('canvas');
            document.getElementById('trendChart').innerHTML = '';
            document.getElementById('trendChart').appendChild(ctx);
            
            if (trendChart) {
                trendChart.destroy();
            }
            
            const labels = dataPoints.map(dp => new Date(dp.timestamp).toLocaleString());
            const values = dataPoints.map(dp => dp.numericValue !== null ? dp.numericValue : NaN);
            
            trendChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: currentTrendName,
                        data: values,
                        borderColor: '#667eea',
                        backgroundColor: 'rgba(102, 126, 234, 0.1)',
                        tension: 0.4,
                        fill: true,
                        pointRadius: 3,
                        pointHoverRadius: 5
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: true,
                            position: 'top'
                        },
                        tooltip: {
                            mode: 'index',
                            intersect: false
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: false,
                            grid: {
                                color: 'rgba(0, 0, 0, 0.1)'
                            }
                        },
                        x: {
                            grid: {
                                display: false
                            },
                            ticks: {
                                maxTicksLimit: 10,
                                maxRotation: 45,
                                minRotation: 45
                            }
                        }
                    }
                }
            });
        }

        async function loadTrendStats(hours) {
            try {
                const response = await fetch(`/api/opc/trend/${encodeURIComponent(currentTrendTag)}/stats?hours=${hours}`);
                const data = await response.json();
                
                if (data.success && data.stats) {
                    const stats = data.stats;
                    document.getElementById('trendStats').innerHTML = `
                        <div class="stat-card">
                            <div class="stat-label">Data Points</div>
                            <div class="stat-value">${stats.count}</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-label">Minimum</div>
                            <div class="stat-value">${stats.min !== null ? stats.min.toFixed(2) : 'N/A'}</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-label">Maximum</div>
                            <div class="stat-value">${stats.max !== null ? stats.max.toFixed(2) : 'N/A'}</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-label">Average</div>
                            <div class="stat-value">${stats.average !== null ? stats.average.toFixed(2) : 'N/A'}</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-label">Current Value</div>
                            <div class="stat-value">${stats.lastValue || 'N/A'}</div>
                        </div>
                    `;
                }
            } catch (err) {
                console.error('Error loading trend stats:', err);
            }
        }

        // Close modal when clicking outside
        window.onclick = function(event) {
            const modal = document.getElementById('trendModal');
            if (event.target == modal) {
                closeTrendModal();
            }
        }
    </script>
</body>
</html>
