        async function addToLogging(tagId) {
            if (!canManageLogging) {
                alert('⚠️ Access Denied: Only Administrator can manage logging');
                return;
            }
            
            // Check for duplicates
            if (loggingConfig.selectedTags.includes(tagId)) {
                alert('This tag is already in logging');
                return;
            }

            try {
                await connection.invoke("AddTagToLogging", tagId);
                loggingConfig.selectedTags.push(tagId);
                updateLoggingTagSelection();
                updateLoggingUI();
                updateStatus(`Added ${tagId} to logging`, "connected");
            } catch (err) {
                console.error("Error adding tag to logging:", err);
                alert('Error adding tag to logging: ' + err.message);
            }
        }

        async function removeFromLogging(tagId) {
            if (!canManageLogging) {
                alert('⚠️ Access Denied: Only Administrator can manage logging');
                return;
            }
            
            try {
                await connection.invoke("RemoveTagFromLogging", tagId);
                loggingConfig.selectedTags = loggingConfig.selectedTags.filter(t => t !== tagId);
                updateLoggingTagSelection();
                updateLoggingUI();
                updateStatus(`Removed ${tagId} from logging`, "connected");
            } catch (err) {
                console.error("Error removing tag from logging:", err);
                alert('Error removing tag from logging: ' + err.message);
