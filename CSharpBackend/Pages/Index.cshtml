        // ===== Historian DB Trends (SCADA-style) =====
        function toLocalIso(date) {
            const offsetMs = date.getTimezoneOffset() * 60000;
            return new Date(date.getTime() - offsetMs).toISOString().slice(0, 16);
        }

        function setHistRangeHours(hours) {
            const end = new Date();
            const start = new Date(end.getTime() - hours * 3600 * 1000);
            document.getElementById('histEnd').value = toLocalIso(end);
            document.getElementById('histStart').value = toLocalIso(start);
        }

        function renderHistTagCount() {
            document.getElementById('histSelectedCount').textContent = histSelectedTags.size;
            document.getElementById('histTagCount').textContent = histTagsCache.length;
        }

        async function loadHistorianTags() {
            const source = document.getElementById('histSourceSelect').value;
            const search = document.getElementById('histSearchInput').value.trim();
            const params = new URLSearchParams();
            if (source) params.append('source', source);
            if (search) params.append('search', search);

            try {
                const res = await fetch('/api/historian-browser/tags' + (params.toString() ? '?' + params.toString() : ''));
                const json = await res.json();
                if (json.success) {
                    histTagsCache = json.data || [];
                    renderHistorianTags(histTagsCache);
                } else {
                    alert('Failed to load tags: ' + json.error);
                }
            } catch (err) {
                console.error('Historian tags error', err);
                alert('Failed to load historian tags');
            }
        }

        function renderHistorianTags(tags) {
            const list = document.getElementById('histTagList');
            if (!list) return;

            if (!tags || tags.length === 0) {
                list.innerHTML = '<p style="color:#777;">No historian rows found. Confirm data logging.</p>';
                renderHistTagCount();
                return;
            }

            // Remove selections that no longer exist in current list
            const availableSet = new Set(tags.map(t => t.tagId));
            histSelectedTags.forEach(t => { if (!availableSet.has(t)) histSelectedTags.delete(t); });

            const rows = tags.map((t, idx) => {
                const checked = histSelectedTags.has(t.tagId);
                const lastTime = t.lastTime ? new Date(t.lastTime).toLocaleString() : 'n/a';
                return `
                    <label style="display:flex; align-items:flex-start; gap:8px; padding:8px; background:white; border-radius:8px; border:1px solid #e0e0e0;">
                        <input type="checkbox" ${checked ? 'checked' : ''} onchange="toggleHistTag('${t.tagId.replace(/'/g, "\\'")}')" style="margin-top:4px;">
                        <div style="flex:1;">
                            <div style="font-weight:600;">${t.tagId}</div>
                            <div style="font-size:0.85em; color:#555;">Source: ${t.sampleSource || 'unknown'} | Last: ${lastTime}</div>
                            <div style="font-size:0.8em; color:#777;">Rows: ${t.total}</div>
                        </div>
                    </label>`;
            }).join('');

            list.innerHTML = rows;
            renderHistTagCount();
        }

        function toggleHistTag(tagId) {
            if (histSelectedTags.has(tagId)) histSelectedTags.delete(tagId); else histSelectedTags.add(tagId);
            renderHistTagCount();
        }

