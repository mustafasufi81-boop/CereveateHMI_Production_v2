        function updateLogTrends(trendData) {
            const container = document.getElementById("logTrendContainer");
            
            console.log(`[UPDATE TRENDS] Called with ${Object.keys(trendData).length} tags`);
            console.log(`[UPDATE TRENDS] Selected tags: ${selectedLogTags.size}`);
            console.log(`[UPDATE TRENDS] selectedLogTags content:`, Array.from(selectedLogTags));
            console.log(`[UPDATE TRENDS] trendData keys:`, Object.keys(trendData));
            console.log(`[UPDATE TRENDS] Container exists: ${!!container}`);
            console.log(`[UPDATE TRENDS] Container dimensions: ${container?.offsetWidth}x${container?.offsetHeight}`);
            console.log(`[UPDATE TRENDS] Container style:`, container?.style.cssText);
            
            // Clear existing charts
            Object.values(logViewerCharts).forEach(chart => chart.destroy());
            logViewerCharts = {};

            // Only render charts for selected tags
            if (selectedLogTags.size === 0) {
                container.innerHTML = '<p style="color: #999; text-align: center; padding: 40px;">Select tags above to view trends</p>';
                return;
            }

            container.innerHTML = '';
            console.log(`[UPDATE TRENDS] Container cleared, starting chart creation...`);
            
            let chartsCreated = 0;

            selectedLogTags.forEach(tagId => {
                if (!trendData[tagId]) {
                    console.error(`[UPDATE TRENDS ERROR] Tag "${tagId}" is in selectedLogTags but NOT in trendData!`);
                    return; // Skip if no data for this tag
                }
                
                const points = trendData[tagId];
                console.log(`[UPDATE TRENDS] ✓ Creating chart ${chartsCreated + 1} for ${tagId} with ${points.length} points`);
                
                const chartHeight = trendViewerConfig?.chartHeight || 350;
                const wrapper = document.createElement('div');
                wrapper.className = 'chart-wrapper';
                wrapper.style.height = `${chartHeight}px`;
                wrapper.innerHTML = `
                    <div class="chart-title">
                        <span>${tagId}</span>
                        <span style="font-size: 0.85em; color: #666;">${points.length} points</span>
                    </div>
                    <canvas id="logChart_${tagId.replace(/[^a-zA-Z0-9]/g, '_')}" style="height: 290px;"></canvas>
                `;
                container.appendChild(wrapper);

                const ctx = wrapper.querySelector('canvas').getContext('2d');
                
                logViewerCharts[tagId] = new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: points.map(p => new Date(p.timestamp).toLocaleString()),
                        datasets: [{
                            label: tagId,
                            data: points.map(p => {
                                const val = parseFloat(p.value);
                                return isNaN(val) ? null : val;
                            }),
                            borderColor: getRandomColor(),
                            backgroundColor: 'rgba(0,0,0,0)',
                            borderWidth: 2,
                            pointRadius: 1,
                            tension: 0.1
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: true }
                        },
                        scales: {
                            x: {
                                display: true,
                                ticks: { maxTicksLimit: 10 }
                            },
                            y: {
                                display: true,
                                beginAtZero: false
                            }
                        },
                        animation: false
                    }
                });
                chartsCreated++;
                console.log(`[UPDATE TRENDS] Chart ${chartsCreated} appended to container. Container now has ${container.children.length} children`);
            });
            
            console.log(`[UPDATE TRENDS] ===== COMPLETE: Created ${chartsCreated} charts total =====`);
            console.log(`[UPDATE TRENDS] Final container children count: ${container.children.length}`);
            console.log(`[UPDATE TRENDS] Container scroll height: ${container.scrollHeight}px`);
        }

