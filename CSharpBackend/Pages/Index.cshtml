        async function addSelectedLoggingTags() {
            if (!isAdmin) {
                alert('⚠️ Access Denied: Only Administrator can manage logging');
                return;
            }

            const checkboxes = document.querySelectorAll('.available-logging-checkbox:checked');
            
            if (checkboxes.length === 0) {
                alert('Please select at least one tag');
                return;
            }

            let addedCount = 0;
            let skippedCount = 0;

            for (const checkbox of checkboxes) {
                const tagId = checkbox.dataset.tagId;

                if (loggingConfig.selectedTags.includes(tagId)) {
                    skippedCount++;
                    continue;
                }

                try {
                    await connection.invoke("AddTagToLogging", tagId);
                    loggingConfig.selectedTags.push(tagId);
                    checkbox.checked = false;
                    addedCount++;
                } catch (err) {
                    console.error(`Error adding tag ${tagId} to logging:`, err);
                }
            }

            updateLoggingTagSelection();
            updateLoggingUI();
            
            if (addedCount > 0) {
                updateStatus(`Added ${addedCount} tag(s) to logging${skippedCount > 0 ? ` (${skippedCount} already in logging)` : ''}`, "connected");
            } else if (skippedCount > 0) {
                alert(`All selected tags are already in logging`);
            }
        }

