        async function loadLogFile() {
            const fileName = document.getElementById("logFileSelect").value;
            if (!fileName) {
                alert('Please select a log file');
                return;
            }

            currentLogFile = fileName;

            try {
                updateStatus("Loading log file...", "loading");

                // Get summary
                const summary = await connection.invoke("GetLogFileSummary", fileName);
                
                // Update cards
                document.getElementById("viewerFileName").textContent = summary.fileName || fileName;
                document.getElementById("viewerRecordCount").textContent = (summary.totalRows || 0).toLocaleString();
                document.getElementById("viewerTagCount").textContent = summary.tagCount || 0;

                if (summary.firstTimestamp && summary.lastTimestamp) {
                    const firstTime = new Date(summary.firstTimestamp);
                    const lastTime = new Date(summary.lastTimestamp);
                    document.getElementById("viewerTimeRange").textContent = 
                        `${firstTime.toLocaleString()} - ${lastTime.toLocaleString()}`;
                } else {
                    document.getElementById("viewerTimeRange").textContent = "-";
                }

                // Load actual data - use configured max records
                const maxRecords = trendViewerConfig?.tableMaxRecords || 100;
                const logData = await connection.invoke("GetLogData", fileName, maxRecords);
                
                if (logData && logData.records && logData.records.length > 0) {
                    updateLogTable(logData.records);
                } else {
                    const tbody = document.getElementById("logTableBody");
                    tbody.innerHTML = '<tr><td colspan="5" style="padding: 40px; text-align: center; color: #999;">No records found</td></tr>';
                }

                // Load trend data - use configured points per tag
                const pointsPerTag = trendViewerConfig?.defaultPointsPerTag || 500;
                const trendData = await connection.invoke("GetLogTrendData", fileName, pointsPerTag);
                console.log(`[TREND DATA] Received ${Object.keys(trendData).length} tags:`, Object.keys(trendData));
                loadedLogTrendData = trendData;
                
                // Calculate ACTUAL time range from trend data (not full file range)
                let firstTrendTime = null;
                let lastTrendTime = null;
                
                Object.values(trendData).forEach(points => {
                    if (points && points.length > 0) {
                        const firstPoint = new Date(points[0].timestamp);
                        const lastPoint = new Date(points[points.length - 1].timestamp);
                        
                        if (!firstTrendTime || firstPoint < firstTrendTime) firstTrendTime = firstPoint;
                        if (!lastTrendTime || lastPoint > lastTrendTime) lastTrendTime = lastPoint;
                    }
                });
                
                // Update time range to show ACTUAL trend data range
                if (firstTrendTime && lastTrendTime) {
                    document.getElementById("viewerTimeRange").textContent = 
                        `${firstTrendTime.toLocaleString()} - ${lastTrendTime.toLocaleString()}`;
                    console.log(`[TIME RANGE] Trend data spans: ${firstTrendTime} to ${lastTrendTime}`);
                }
                
                updateLogTagSelection(trendData);
                
                // Select only FIRST N tags by default (based on config)
                const allTags = Object.keys(trendData);
                const maxTrends = trendViewerConfig?.maxTrendCount || 20;
                const defaultTrends = trendViewerConfig?.defaultTrendCount || 20;
                selectedLogTags = new Set(allTags.slice(0, Math.min(defaultTrends, allTags.length)));
                
                console.log("=".repeat(80));
                console.log(`[LOAD FILE DEBUG] Total tags in trendData: ${allTags.length}`);
                console.log(`[LOAD FILE DEBUG] All tags:`, allTags);
                console.log(`[LOAD FILE DEBUG] Config maxTrends: ${maxTrends}, defaultTrends: ${defaultTrends}`);
                console.log(`[LOAD FILE DEBUG] selectedLogTags size: ${selectedLogTags.size}`);
                console.log(`[LOAD FILE DEBUG] selectedLogTags content:`, Array.from(selectedLogTags));
                console.log("=".repeat(80));
                
                // Update checkboxes to reflect selection
                document.querySelectorAll('.tag-checkbox').forEach(checkbox => {
                    if (checkbox) checkbox.checked = selectedLogTags.has(checkbox.dataset.tag);
                });
                const selectAllCheckbox = document.getElementById('selectAllTagsCheckbox');
                if (selectAllCheckbox) selectAllCheckbox.checked = false;
                
                updateLogTrends(trendData);

                updateStatus(`Loaded ${(summary.totalRows || 0).toLocaleString()} records`, "connected");
            } catch (err) {
                console.error("Error loading log file:", err);
                updateStatus("Error: " + err.message, "disconnected");
            }
        }

