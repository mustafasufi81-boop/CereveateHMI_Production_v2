@page
@{
    ViewData["Title"] = "OPC DA Browser";
    var userRole = HttpContext.Session.GetString("UserRole") ?? "Viewer";
    var username = HttpContext.Session.GetString("Username") ?? "Guest";
    var isAdmin = userRole == "Administrator";
    var isLoggingAdmin = username == "opcadmin";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />
    <link rel="icon" href="data:,">
    <title>OPC DA Web Browser</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.0/signalr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <!-- HIGH-PERFORMANCE: Virtual DOM, virtual scrolling, chart batching, Web Worker -->
    <script src="/performance-optimizations.js"></script>
    <!-- PLC Tag Browser Module -->
    <script src="/js/plc/plc-tag-browser.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }
        .container {
            max-width: 1400px;
            margin: 0 auto;
            background: white;
            border-radius: 15px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            overflow: hidden;
        }
        .header {
            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
            color: white;
            padding: 30px;
            text-align: center;
            position: relative;
        }
        .company-branding {
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 20px;
            gap: 20px;
        }
        .company-logo {
            width: 80px;
            height: 80px;
            background: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
            position: relative;
            overflow: hidden;
        }
        .company-logo svg {
            width: 60px;
            height: 60px;
        }
        .company-name {
            font-size: 2.8em;
            font-weight: bold;
            letter-spacing: 2px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
        }
        .header h1 { font-size: 2.2em; margin-bottom: 10px; margin-top: 10px; }
        .header p { font-size: 1.1em; opacity: 0.9; }
        .section {
            padding: 25px;
            border-bottom: 2px solid #e0e0e0;
        }
        .section h3 {
            color: #1e3c72;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .controls {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            align-items: center;
        }
        button {
            padding: 12px 24px;
            font-size: 1em;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            color: white;
            transition: transform 0.2s;
        }
        button:hover { transform: translateY(-2px); }
        button.discover { background: #28a745; }
        button.connect { background: #007bff; }
        
        /* Status bar */
        .status {
            padding: 15px 25px;
            font-size: 1.1em;
            font-weight: 600;
            text-align: center;
            border-bottom: 2px solid #e0e0e0;
        }
        .status.disconnected {
            background: #f8d7da;
            color: #721c24;
        }
        .status.loading {
            background: #fff3cd;
            color: #856404;
        }
        .status.connected {
            background: #d4edda;
            color: #155724;
        }
        
        /* Tabs */
        .tabs {
            display: flex;
            background: #f8f9fa;
            border-bottom: 3px solid #1e3c72;
            flex-wrap: wrap;
        }
        .tab {
            flex: 1;
            padding: 15px 20px;
            border: none;
            background: #e9ecef;
            color: #495057;
            cursor: pointer;
            font-weight: 600;
            font-size: 1em;
            transition: all 0.3s;
            border-right: 1px solid #dee2e6;
        }
        .tab:hover {
            background: #d4d8dd;
            transform: translateY(-2px);
        }
        .tab.active {
            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
            color: white;
            border-bottom: 3px solid #28a745;
        }
        
        /* Tab content */
        .tab-content {
            display: none;
        }
        .tab-content.active {
            display: block;
        }
        
        /* Content and panels */
        .content {
            padding: 25px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            align-items: start;
        }
        .panel {
            background: #f8f9fa;
            border: 2px solid #e0e0e0;
            border-radius: 10px;
            padding: 20px;
        }
        .panel-header {
            font-weight: 600;
            color: #1e3c72;
            margin-bottom: 15px;
            font-size: 1.1em;
        }
        
        /* Value cards */
        .value-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
            gap: 15px;
            margin-top: 20px;
        }
        .value-card {
            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
            transition: transform 0.3s;
        }
        .value-card:hover {
            transform: translateY(-5px);
        }
        .card-title {
            color: white;
            font-size: 1em;
            margin-bottom: 10px;
            opacity: 0.9;
        }
        .card-value {
            color: white;
            font-size: 2em;
            font-weight: bold;
            margin-bottom: 5px;
        }
        .card-timestamp {
            color: rgba(255,255,255,0.7);
            font-size: 0.85em;
        }
        
        .trend-header {
            padding: 15px 20px;
            border-bottom: 2px solid #e0e0e0;
            display: flex;
            justify-content: space-between;
            align-items: center;
            cursor: pointer;
            user-select: none;
        }
        .trend-header:hover {
            background: #e9ecef;
        }
        .collapse-arrow {
            display: inline-block;
            transition: transform 0.3s;
            font-size: 1.2em;
            margin-right: 8px;
        }
        .collapse-arrow.collapsed {
            transform: rotate(-90deg);
        }
        .collapsible-content {
            max-height: 2000px;
            overflow: hidden;
            transition: max-height 0.3s ease-out;
        }
        .collapsible-content.collapsed {
            max-height: 0;
        }
        .trend-controls {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }
        .trend-list {
            padding: 20px;
            max-height: 300px;
            overflow-y: auto;
        }
        .trend-item {
            background: #f8f9fa;
            padding: 12px;
            margin-bottom: 8px;
            border-radius: 6px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .trend-item.selected {
            background: #d4edda;
            border-left: 4px solid #28a745;
        }
        .btn {
            padding: 8px 16px;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.2s;
        }
        .btn-primary { background: #007bff; color: white; }
        .btn-success { background: #28a745; color: white; }
        .btn-danger { background: #dc3545; color: white; }
        .btn-warning { background: #ffc107; color: #333; }
        .btn-info { background: #17a2b8; color: white; }
        .btn-sm { padding: 6px 12px; font-size: 0.85em; }
        .btn:hover { transform: translateY(-2px); box-shadow: 0 4px 8px rgba(0,0,0,0.2); }
        .btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
        
        /* PLC Gateway Styles */
        .status-badge {
            padding: 4px 10px;
            border-radius: 12px;
            font-size: 0.85em;
            font-weight: 500;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }
        .status-badge.connected { background: #d5f5e3; color: #27ae60; }
        .status-badge.disconnected { background: #fadbd8; color: #e74c3c; }
        .protocol-badge {
            background: #e8f4fd;
            color: #2980b9;
            padding: 3px 8px;
            border-radius: 4px;
            font-size: 0.85em;
            font-weight: 500;
        }
        .plc-summary-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 15px;
            margin-bottom: 20px;
        }
        .plc-summary-card {
            background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
            border: 1px solid #dee2e6;
            border-radius: 10px;
            padding: 15px;
            text-align: center;
        }
        .plc-summary-card .value {
            font-size: 2em;
            font-weight: bold;
            color: #2c3e50;
        }
        .plc-summary-card .label {
            font-size: 0.85em;
            color: #7f8c8d;
            margin-top: 5px;
        }
        .modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0,0,0,0.5);
        }
        
        .chart-container {
            position: relative;
            padding: 20px;
            background: white;
        }
        
        /* Scrollable charts container */
        #logTrendContainer {
            max-height: 8000px;
            overflow-y: auto;
            overflow-x: hidden;
        }
        
        /* Custom scrollbar styling */
        #logTrendContainer::-webkit-scrollbar {
            width: 12px;
        }
        
        #logTrendContainer::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 6px;
        }
        
        #logTrendContainer::-webkit-scrollbar-thumb {
            background: linear-gradient(135deg, #667eea, #764ba2);
            border-radius: 6px;
            border: 2px solid #f1f1f1;
        }
        
        #logTrendContainer::-webkit-scrollbar-thumb:hover {
            background: linear-gradient(135deg, #1e3c72, #2a5298);
        }
        .chart-wrapper {
            background: white;
            border: 2px solid #e0e0e0;
            border-radius: 10px;
            padding: 20px;
            margin-bottom: 20px;
        }
        .chart-title {
            font-weight: 600;
            color: #1e3c72;
            margin-bottom: 10px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .monitored-tags-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 10px;
            padding: 20px;
            max-height: 400px;
            overflow-y: auto;
        }
        .tag-checkbox {
            display: flex;
            align-items: center;
            padding: 10px;
            background: #f8f9fa;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.2s;
        }
        .tag-checkbox:hover {
            background: #e9ecef;
            transform: translateX(3px);
        }
        .tag-checkbox input[type="checkbox"] {
            margin-right: 8px;
            width: 18px;
            height: 18px;
            cursor: pointer;
        }
        .tag-checkbox.checked {
            background: #d4edda;
            border-left: 4px solid #28a745;
        }
        .tree-container {
            max-height: 600px;
            overflow-y: auto;
            overflow-x: auto;
        }
        .tree-folder {
            margin-left: 20px;
            border-left: 2px solid #e0e0e0;
            padding-left: 10px;
        }
        .tree-node {
            padding: 8px 12px;
            margin: 4px 0;
            background: #f8f9fa;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.2s;
            user-select: none;
        }
        .tree-node:hover {
            background: #e9ecef;
            transform: translateX(3px);
        }
        .tree-node.folder {
            font-weight: 600;
            color: #1e3c72;
            background: #e7f3ff;
            position: relative;
            padding-left: 30px;
        }
        .tree-node.folder .folder-icon {
            position: absolute;
            left: 8px;
            top: 8px;
            transition: transform 0.2s;
            display: inline-block;
        }
        .tree-node.folder.collapsed .folder-icon {
            transform: rotate(-90deg);
        }
        .tree-node.leaf {
            padding-left: 30px;
        }
        .tree-node.leaf::before {
            content: "🏷️ ";
            position: absolute;
            left: 8px;
        }
        .tree-children {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.3s ease;
        }
        .tree-children.expanded {
            max-height: 5000px;
        }
        .value-card-with-trend {
            position: relative;
        }
        .trend-checkbox-container {
            position: absolute;
            top: 15px;
            right: 15px;
        }
        .trend-checkbox-container input[type="checkbox"] {
            width: 20px;
            height: 20px;
            cursor: pointer;
        }
        .trend-checkbox-container label {
            color: white;
            font-size: 0.85em;
            margin-left: 5px;
            cursor: pointer;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <div class="company-branding">
                <div class="company-logo">
                    <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="50" cy="50" r="48" fill="none" stroke="#5DCCB4" stroke-width="4"/>
                        <path d="M 30 25 L 50 65 L 70 25" fill="none" stroke="#1e3c72" stroke-width="8" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M 35 35 L 50 65 L 65 35" fill="none" stroke="#1e3c72" stroke-width="8" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
                <div class="company-name">CEREVEATE</div>
            </div>
            <h1 style="margin-top: 15px;">OPC DA Web Browser</h1>
            <p>Real-time OPC Data Monitoring & Analysis Platform</p>
            <div style="position: absolute; top: 20px; right: 30px; display: flex; align-items: center; gap: 15px;">
                <div style="color: white; background: rgba(0,0,0,0.2); padding: 8px 15px; border-radius: 20px;">
                    <span style="font-size: 0.95em; font-weight: 500;">@username</span>
                </div>
                <button onclick="openSettingsModal()" style="background: #3498db; color: white; border: none; padding: 8px 15px; border-radius: 8px; cursor: pointer; font-weight: 500; font-size: 0.9em;">
                    ⚙️ Settings
                </button>
                <button onclick="logout()" style="background: #e74c3c; color: white; border: none; padding: 8px 15px; border-radius: 8px; cursor: pointer; font-weight: 500; font-size: 0.9em;">
                    🚪 Logout
                </button>
            </div>
        </div>

        @if (isAdmin)
        {
        <!-- Local OPC Servers Section -->
        <div class="section">
            <h3>💻 Local OPC Servers</h3>
            <div class="controls">
                <button class="discover" onclick="discoverLocalServers()">🔍 DISCOVER</button>
                <select id="localServerSelect" disabled>
                    <option>Click Discover to find servers...</option>
                </select>
                <input type="text" id="localServerName" placeholder="Server Name (optional)" style="min-width:200px;">
                <button class="connect" id="localConnectBtn" onclick="connectToLocal()" disabled>🔗 CONNECT</button>
            </div>
        </div>
        }

        @if (isAdmin)
        {
        <!-- Remote OPC Servers Section -->
        <div class="section">
            <h3>🌍 Remote OPC Servers</h3>
            <div class="controls">
                <input type="text" id="remoteHost" placeholder="IP Address (e.g., 172.16.160.16)" style="min-width:300px;">
                <button class="discover" onclick="discoverRemoteServers()">🔍 DISCOVER</button>
                <select id="remoteServerSelect" disabled>
                    <option>Enter IP and click Discover...</option>
                </select>
                <input type="text" id="remoteServerName" placeholder="Server Name (optional)" style="min-width:200px;">
                <button class="connect" id="remoteConnectBtn" onclick="connectToRemote()" disabled>🔗 CONNECT</button>
            </div>
        </div>
        }

        <!-- Status -->
        <div class="status @(isAdmin ? "disconnected" : "connected")" id="statusLabel">@(isAdmin ? "⚫ Disconnected" : "🟢 Connected (View-Only Mode)")</div>

        <!-- Tabs -->
        <div class="tabs">
            @if (isAdmin)
            {
                <button class="tab active" onclick="switchTab('monitoring')">📊 Monitoring</button>
                <button class="tab" onclick="switchTab('trending')">📈 Trending</button>
                @if (isLoggingAdmin)
                {
                    <button class="tab" onclick="switchTab('logging')">📝 Logging</button>
                }
                <button class="tab" onclick="switchTab('logviewer')">📂 Log Viewer</button>
                @* <button class="tab" onclick="window.location.href='/HistorianMonitor'">🗄️ Historian Monitor</button> *@
                <button class="tab" onclick="window.location.href='/Archive'">📦 Archive</button>
                <button class="tab" onclick="switchTab('plcgateway')">🔌 PLC Gateway</button>
            }
            else
            {
                <button class="tab active" onclick="switchTab('logviewer')">📂 Log Viewer</button>
            }
        </div>

        @if (isAdmin)
        {
        <!-- Monitoring Tab -->
        <div id="monitoring-tab" class="tab-content active">
            <!-- Content Area -->
            <div class="content">
                <div class="panel">
                    <div class="panel-header" style="display: flex; justify-content: space-between; align-items: center;">
                        <span>📁 Available Tags <span id="tagCount">(0 tags)</span></span>
                        <div style="display: flex; gap: 8px;">
                            <button class="btn btn-sm btn-primary" onclick="selectAllAvailableTags()" style="padding: 6px 12px; font-size: 0.85em;">Select All</button>
                            <button class="btn btn-sm btn-warning" onclick="deselectAllAvailableTags()" style="padding: 6px 12px; font-size: 0.85em;">Deselect All</button>
                            <button class="btn btn-sm btn-success" onclick="addSelectedTags()" style="padding: 6px 12px; font-size: 0.85em;">Add Selected</button>
                        </div>
                    </div>
                    <div class="panel-body">
                        <div style="margin-bottom: 12px;">
                            <input type="text" id="tagSearchInput" placeholder="🔍 Search tags..." 
                                   style="width: 100%; padding: 10px; border: 2px solid #ddd; border-radius: 6px; font-size: 0.95em; outline: none;"
                                   oninput="filterTags(this.value)"
                                   onkeyup="if(event.key === 'Escape') { this.value = ''; filterTags(''); }">
                        </div>
                        <div class="tree-container" id="tagTree">
                            <p style="color: #999;">Connect to a server to see tags</p>
                        </div>
                    </div>
                </div>

                <div class="panel">
                    <div class="panel-header">
                        📊 Monitored Values (<span id="monitoredCount">0</span>)
                        @if (isAdmin)
                        {
                        <div style="margin-left: auto; display: flex; gap: 10px;">
                            <button class="btn btn-sm btn-danger" onclick="removeAllMonitoredTags()">Remove All</button>
                        </div>
                        }
                    </div>
                    <div class="panel-body" id="valueCards">
                        <p style="color: #999;">Click on tags to monitor them</p>
                    </div>
                </div>
            </div>
        </div>

        }

        @if (isAdmin)
        {
        <!-- Trending Tab -->
        <div id="trending-tab" class="tab-content">
            <div class="trend-panel">
                <div class="trend-header">
                    <h3 style="margin: 0; color: #1e3c72;">📈 Active Trends (<span id="trendCount">0</span>)</h3>
                    @if (isAdmin)
                    {
                    <div class="trend-controls">
                        <button class="btn btn-danger" onclick="removeSelectedTrends()">Remove Selected Trends</button>
                        <button class="btn btn-danger" onclick="clearAllTrends()">Clear All Trends</button>
                    </div>
                    }
                </div>
                <div class="trend-list" id="trendList">
                    <p style="color: #999;">Enable trend checkboxes in Monitoring tab to see trends here</p>
                </div>
            </div>

            <div class="chart-container" id="chartContainer">
                <p style="color: #999; text-align: center; padding: 40px;">Enable trend checkboxes to start trending</p>
            </div>
        </div>

        }

        @if (isAdmin && isLoggingAdmin)
        {
        <!-- Logging Tab (opcadmin only) -->
        <div id="logging-tab" class="tab-content">
            <div class="trend-panel">
                <div class="trend-header">
                    <h3 style="margin: 0; color: #1e3c72;">📝 Data Logging Configuration</h3>
                    <div class="trend-controls">
                        <label style="display: flex; align-items: center; gap: 10px; background: white; padding: 10px 20px; border-radius: 8px; cursor: pointer;">
                            <input type="checkbox" id="loggingEnabled" onchange="toggleLogging()" style="width: 20px; height: 20px;">
                            <span style="font-weight: 600; color: #1e3c72;">Enable Logging</span>
                        </label>
                        <div style="display: flex; gap: 15px; align-items: center;">
                            <div style="display: flex; flex-direction: column; gap: 5px;">
                                <label style="font-size: 12px; color: #666; font-weight: 600;">Parquet File Write Interval:</label>
                                <select id="loggingInterval" onchange="updateLoggingInterval()" style="padding: 10px; border-radius: 8px; border: 2px solid #e0e0e0;">
                                    <option value="500">0.5 seconds (500ms)</option>
                                    <option value="1000">1 second</option>
                                    <option value="2000">2 seconds</option>
                                    <option value="3000">3 seconds</option>
                                    <option value="4000">4 seconds</option>
                                    <option value="5000">5 seconds</option>
                                    <option value="10000">10 seconds</option>
                                    <option value="30000">30 seconds</option>
                                    <option value="60000">1 minute</option>
                                </select>
                            </div>
                            <div style="background: #e3f2fd; padding: 10px 15px; border-radius: 8px; border: 2px solid #2196f3;">
                                <div style="font-size: 11px; color: #1565c0; font-weight: 600; margin-bottom: 3px;">OPC Polling Rate:</div>
                                <div style="font-size: 14px; color: #0d47a1; font-weight: bold;">Fixed at 1000ms</div>
                                <div style="font-size: 10px; color: #1976d2; margin-top: 2px;">⚡ (Restart to change)</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Two-column layout for tag selection -->
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; padding: 20px;">
                    <!-- Left: Current Selected Tags for Logging -->
                    <div style="background: #f8f9fa; border-radius: 12px; padding: 20px; border: 2px solid #667eea;">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; flex-wrap: wrap; gap: 10px;">
                            <h4 style="margin: 0; color: #667eea;">✅ Selected for Logging (<span id="selectedLoggingCount">0</span>)</h4>
                            @if (isLoggingAdmin)
                            {
                            <div style="display: flex; gap: 8px;">
                                <button class="btn btn-sm btn-primary" onclick="selectAllSelectedLoggingTags()" style="padding: 6px 12px; font-size: 0.85em;">Select All</button>
