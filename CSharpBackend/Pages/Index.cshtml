                container.innerHTML += `
                    <div style="padding: 8px; background: #fff3cd; border: 1px solid #ffeeba; border-radius: 4px; margin-top: 8px; font-size: 0.85em; color: #856404;">
                        Showing first ${limitedTags.length} tags (${tags.length} available). Use filtering or adjust configuration to view additional tags.
                    </div>
                `;
            }
            
            // selectedLogTags is already set in loadLogFile() - don't override
        }

        function toggleLogTag(tagId) {
            const maxTrends = trendViewerConfig?.maxTrendCount || 20;
            
            if (selectedLogTags.has(tagId)) {
                selectedLogTags.delete(tagId);
            } else {
                // Enforce maximum 20 trends
                if (selectedLogTags.size >= maxTrends) {
                    alert(`Maximum ${maxTrends} trends can be displayed at once. Please deselect another trend first.`);
                    // Uncheck the checkbox
                    const checkbox = document.querySelector(`.tag-checkbox[data-tag="${tagId}"]`);
                    if (checkbox) checkbox.checked = false;
                    return;
                }
                selectedLogTags.add(tagId);
            }

            // Filter trend data for selected tags
            const filteredData = {};
            selectedLogTags.forEach(tag => {
                if (loadedLogTrendData[tag]) {
                    filteredData[tag] = loadedLogTrendData[tag];
                }
            });

            updateLogTrends(filteredData);
        }

        function toggleAllLogTags() {
            const maxTrends = trendViewerConfig?.maxTrendCount || 20;
            const masterCheckbox = document.getElementById('selectAllTagsCheckbox');
            const checkboxes = document.querySelectorAll('#logTagSelection .tag-checkbox');
            const isChecked = masterCheckbox.checked;
            
            selectedLogTags.clear();
            
            if (isChecked) {
                // Select only first 20 tags
                let count = 0;
                checkboxes.forEach(cb => {
                    const tagId = cb.getAttribute('data-tag');
                    if (count < maxTrends) {
                        cb.checked = true;
                        selectedLogTags.add(tagId);
                        count++;
                    } else {
                        cb.checked = false;
                    }
                });
                
                if (checkboxes.length > maxTrends) {
                    alert(`Only first ${maxTrends} trends selected (maximum limit). Total tags available: ${checkboxes.length}`);
                }
            } else {
                // Uncheck all
                checkboxes.forEach(cb => {
                    cb.checked = false;
                });
            }

            if (isChecked) {
                const filteredData = {};
                selectedLogTags.forEach(tag => {
                    if (loadedLogTrendData[tag]) {
                        filteredData[tag] = loadedLogTrendData[tag];
                    }
                });
                updateLogTrends(filteredData);
            } else {
                document.getElementById("logTrendContainer").innerHTML = 
                    '<p style="color: #999; text-align: center; padding: 40px;">Select tags above to view trends</p>';
            }
        }

        function selectAllLogTags() {
            const masterCheckbox = document.getElementById('selectAllTagsCheckbox');
            if (masterCheckbox) masterCheckbox.checked = true;
            
            const checkboxes = document.querySelectorAll('#logTagSelection .tag-checkbox');
            checkboxes.forEach(cb => {
                cb.checked = true;
                const tagId = cb.getAttribute('data-tag');
                selectedLogTags.add(tagId);
            });
            const limitedData = {};
            selectedLogTags.forEach(tagId => {
                if (loadedLogTrendData[tagId]) {
                    limitedData[tagId] = loadedLogTrendData[tagId];
                }
            });
            updateLogTrends(limitedData);
        }

        function deselectAllLogTags() {
            const masterCheckbox = document.getElementById('selectAllTagsCheckbox');
            if (masterCheckbox) masterCheckbox.checked = false;
            
            const checkboxes = document.querySelectorAll('#logTagSelection .tag-checkbox');
            checkboxes.forEach(cb => cb.checked = false);
            selectedLogTags.clear();
            document.getElementById("logTrendContainer").innerHTML = 
                '<p style="color: #999; text-align: center; padding: 40px;">Select tags above to view trends</p>';
        }

        function combineLogTrends() {
            if (selectedLogTags.size === 0) {
                alert('Please select at least one tag');
                return;
            }

            const container = document.getElementById("logTrendContainer");
            
            // Clear existing charts
            Object.values(logViewerCharts).forEach(chart => chart.destroy());
            logViewerCharts = {};

            container.innerHTML = '';

            const wrapper = document.createElement('div');
            wrapper.className = 'chart-wrapper';
            wrapper.style.height = '400px';
            wrapper.innerHTML = `
                <div class="chart-title">
                    <span>Combined Trends</span>
                    <span style="font-size: 0.85em; color: #666;">${selectedLogTags.size} tags</span>
                </div>
                <canvas id="logChart_combined" style="height: 350px;"></canvas>
            `;
            container.appendChild(wrapper);

            const ctx = wrapper.querySelector('canvas').getContext('2d');
            
            const datasets = [];
            const colors = ['#667eea', '#764ba2', '#f093fb', '#4facfe', '#43e97b', '#fa709a', '#fee140', '#30cfd0'];
            let colorIndex = 0;

            selectedLogTags.forEach(tagId => {
                if (loadedLogTrendData[tagId]) {
                    const points = loadedLogTrendData[tagId];
                    datasets.push({
                        label: tagId,
                        data: points.map(p => ({
                            x: new Date(p.timestamp),
                            y: parseFloat(p.value)
                        })),
                        borderColor: colors[colorIndex % colors.length],
                        backgroundColor: 'rgba(0,0,0,0)',
                        borderWidth: 2,
                        pointRadius: 1,
                        tension: 0.1
                    });
                    colorIndex++;
                }
            });

            logViewerCharts['combined'] = new Chart(ctx, {
                type: 'line',
                data: { datasets },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: true, position: 'top' }
                    },
                    scales: {
                        x: {
                            type: 'time',
                            time: {
                                unit: 'minute',
                                displayFormats: { minute: 'HH:mm' }
                            },
                            display: true
                        },
                        y: {
                            display: true,
                            beginAtZero: false
                        }
                    },
                    animation: false
                }
            });
        }

        // ============ AUTO REFRESH & DOWNLOAD FUNCTIONS ============

        function toggleAutoRefresh() {
            if (!currentLogFile) {
                alert('Please load a log file first');
                return;
            }

            isLogAutoRefreshing = !isLogAutoRefreshing;
            const btn = document.getElementById("autoRefreshBtn");

            if (isLogAutoRefreshing) {
                btn.textContent = "⏸️ Pause Monitor";
                btn.classList.remove("btn-info");
                btn.classList.add("btn-danger");
                
                // Refresh every 2 seconds
                logAutoRefreshInterval = setInterval(() => {
                    loadLogFile();
                }, 2000);
                
                updateStatus("Auto-refresh enabled - monitoring log file", "connected");
            } else {
                btn.textContent = "▶️ Auto Monitor";
                btn.classList.remove("btn-danger");
                btn.classList.add("btn-info");
                
                if (logAutoRefreshInterval) {
                    clearInterval(logAutoRefreshInterval);
                    logAutoRefreshInterval = null;
                }
                
                updateStatus("Auto-refresh disabled", "disconnected");
            }
        }

        function logout() {
            if (confirm('Are you sure you want to logout?')) {
                window.location.href = '/Logout';
            }
        }

        async function downloadLogAsCSV() {
            if (!currentLogFile) {
                alert('Please load a log file first');
                return;
            }

            try {
                updateStatus("Creating CSV file...", "loading");

                // Create CSV on server
                const csvFilePath = await connection.invoke("DownloadLogAsCsv", currentLogFile);
                
                if (!csvFilePath) {
                    alert('Failed to create CSV file');
                    return;
                }

                alert(`CSV file created: ${csvFilePath}\n\nCheck your Logs folder.`);
                updateStatus(`CSV created successfully`, "connected");
            } catch (err) {
                console.error("Error downloading CSV:", err);
                updateStatus("Error downloading CSV", "disconnected");
                alert('Error: ' + err.message);
            }
        }

        // Settings Modal Functions
        function openSettingsModal() {
            document.getElementById('settingsModal').style.display = 'flex';
            if (isAdmin) {
                loadUsers(); // Load user list when modal opens
            }
        }

        function closeSettingsModal() {
            document.getElementById('settingsModal').style.display = 'none';
            document.getElementById('changePasswordForm').reset();
            if (isAdmin) {
                document.getElementById('adminChangePasswordForm').reset();
            }
        }

        async function loadUsers() {
            try {
                const response = await fetch('/api/account/admin/users');
                const data = await response.json();

                if (response.ok && data.users) {
                    const userListDiv = document.getElementById('userList');
                    userListDiv.innerHTML = data.users.map(user => `
                        <div style="display: flex; justify-content: space-between; align-items: center; padding: 10px; border-bottom: 1px solid #ddd;">
                            <div>
                                <strong style="color: #333;">${user.username}</strong>
                                <span style="color: #666; font-size: 0.9em; margin-left: 10px;">(${user.role})</span>
                                <span style="color: ${user.isEnabled ? '#28a745' : '#dc3545'}; font-size: 0.85em; margin-left: 10px;">
                                    ${user.isEnabled ? '✅ Active' : '❌ Disabled'}
                                </span>
                            </div>
                            ${user.username === 'admin' ? `
                                <button onclick="toggleUser('${user.username}', ${!user.isEnabled})" 
                                        style="background: ${user.isEnabled ? '#dc3545' : '#28a745'}; color: white; border: none; padding: 6px 12px; border-radius: 6px; cursor: pointer; font-size: 0.85em;">
                                    ${user.isEnabled ? '🚫 Disable' : '✅ Enable'}
                                </button>
                            ` : '<span style="color: #999; font-size: 0.85em;">Cannot be disabled</span>'}
                        </div>
                    `).join('');
                } else {
                    document.getElementById('userList').innerHTML = '<p style="color: #999;">Unable to load users</p>';
                }
            } catch (err) {
                document.getElementById('userList').innerHTML = '<p style="color: #dc3545;">Error loading users</p>';
            }
        }

        async function toggleUser(username, enabled) {
            if (!confirm(`Are you sure you want to ${enabled ? 'enable' : 'disable'} user '${username}'?`)) {
                return;
            }

            try {
                const response = await fetch('/api/account/admin/toggle-user', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ username, enabled })
                });

                const data = await response.json();

                if (response.ok) {
                    alert(data.message);
                    loadUsers(); // Reload user list
                } else {
                    alert(data.message || 'Failed to update user');
                }
            } catch (err) {
                alert('Error updating user: ' + err.message);
            }
        }

        async function changeOwnPassword() {
            const oldPassword = document.getElementById('oldPassword').value;
            const newPassword = document.getElementById('newPassword').value;
            const confirmPassword = document.getElementById('confirmPassword').value;

            if (!oldPassword || !newPassword || !confirmPassword) {
                alert('Please fill in all fields');
                return;
            }

            if (newPassword !== confirmPassword) {
                alert('New passwords do not match');
                return;
            }

            if (newPassword.length < 6) {
                alert('Password must be at least 6 characters');
                return;
            }

            try {
                const response = await fetch('/api/account/change-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ oldPassword, newPassword })
                });

                const data = await response.json();

                if (response.ok) {
                    alert('Password changed successfully!');
                    closeSettingsModal();
                } else {
                    alert(data.message || 'Failed to change password');
                }
            } catch (err) {
                alert('Error changing password: ' + err.message);
            }
        }

        async function changeUserPassword() {
            const targetUsername = document.getElementById('targetUsername').value;
            const newUserPassword = document.getElementById('newUserPassword').value;
            const confirmUserPassword = document.getElementById('confirmUserPassword').value;

            if (!targetUsername || !newUserPassword || !confirmUserPassword) {
                alert('Please fill in all fields');
                return;
            }

            if (newUserPassword !== confirmUserPassword) {
                alert('New passwords do not match');
                return;
            }

            if (newUserPassword.length < 6) {
                alert('Password must be at least 6 characters');
                return;
            }

            try {
                const response = await fetch('/api/account/admin/change-user-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        targetUsername, 
                        newPassword: newUserPassword 
                    })
                });

                const data = await response.json();

                if (response.ok) {
                    alert(`Password changed successfully for user '${targetUsername}'!`);
                    document.getElementById('adminChangePasswordForm').reset();
                } else {
                    alert(data.message || 'Failed to change password');
                }
            } catch (err) {
                alert('Error changing password: ' + err.message);
            }
        }
        
        // HIGH-PERFORMANCE: Cleanup on page unload
        window.addEventListener('beforeunload', () => {
            if (trendWorker) {
                trendWorker.terminate();
                console.log('[PERFORMANCE] TrendWorker terminated');
            }
        });
    </script>

    <!-- Settings Modal -->
    <div id="settingsModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); z-index: 10000; justify-content: center; align-items: center;">
        <div style="background: white; border-radius: 15px; padding: 30px; max-width: 600px; width: 90%; max-height: 80vh; overflow-y: auto;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                <h2 style="margin: 0; color: #1e3c72;">⚙️ Settings</h2>
                <button onclick="closeSettingsModal()" style="background: #e74c3c; color: white; border: none; padding: 8px 15px; border-radius: 8px; cursor: pointer; font-weight: 500;">✕ Close</button>
            </div>

            <!-- Change Own Password Section -->
            <div style="background: #f8f9fa; border-radius: 12px; padding: 20px; margin-bottom: 20px;">
