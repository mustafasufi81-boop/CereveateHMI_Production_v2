    <script>
        console.log("==========SCRIPT LOADED v3.0 - DYNAMIC CONFIG==========");
        console.log("Page loaded at:", new Date().toISOString());
        
        // Role-based access control
        const userRole = '@userRole';
        const username = '@username';
        const isAdmin = userRole === 'Administrator';
        const canManageLogging = username === 'opcadmin';
        
        let connection = new signalR.HubConnectionBuilder()
            .withUrl("/opcHub")
            .withAutomaticReconnect()
            .build();

        let monitoredTags = {};
        let trendCharts = {};
        let trendData = {};
        let selectedTrends = new Set();
        let loggingConfig = { isEnabled: false, selectedTags: [], loggingIntervalMs: 1000 };
        const MAX_TREND_POINTS = 200;
        const AXIS_SMOOTHING = 0.8;  // High value for fast axis response
        let tagMappings = {};
        
        // HIGH-PERFORMANCE: Initialize optimization instances
        let virtualTagGrid = null;
        let virtualTagTree = null;
        let chartBatcher = null;
        let trendWorker = null;
        
        // DYNAMIC CONFIGURATION - Loaded from backend instead of hardcoded
        let trendViewerConfig = {
            defaultPointsPerTag: 20,
            maxPointsPerTag: 20,
            defaultTrendCount: 20,
            maxTrendCount: 20,
            chartContainerMaxHeight: 8000,
            chartHeight: 350,
            tableMaxRecords: 100
        };

        // Load tag name mappings from JSON file
        async function loadTagMappings() {
            try {
                const response = await fetch('/tag-mapping.json');
                if (response.ok) {
                    const data = await response.json();
                    tagMappings = data.mappings || {};
                    console.log('[TAG MAPPING] Loaded', Object.keys(tagMappings).length, 'tag name mappings');
                } else {
                    console.warn('[TAG MAPPING] No mapping file found, using default tag names');
                }
            } catch (err) {
                console.error('[TAG MAPPING] Failed to load mappings:', err);
            }
        }

        // Get friendly name for a tag
        function getFriendlyTagName(tagId) {
            return tagMappings[tagId] || tagId;
        }
        
        // HIGH-PERFORMANCE: Expose functions to global scope for virtual DOM
        window.getFriendlyTagName = getFriendlyTagName;
        window.toggleTrend = toggleTrend;
        window.removeSingleTag = removeSingleTag;
        window.addTagToMonitor = addTagToMonitor;
        window.isAdmin = @Json.Serialize(isAdmin);
        
        // Load trend viewer configuration from backend
        async function loadTrendViewerConfig() {
            try {
                console.log('[CONFIG] Loading trend viewer configuration from backend...');
                const config = await connection.invoke("GetTrendViewerSettings");
                if (config) {
                    trendViewerConfig = config;
                    console.log('[CONFIG] Loaded:', config);
                    
                    // Apply container max-height dynamically
                    const container = document.getElementById('logTrendContainer');
                    if (container) {
                        container.style.maxHeight = `${config.chartContainerMaxHeight}px`;
                        console.log(`[CONFIG] Set container max-height to ${config.chartContainerMaxHeight}px`);
                    }
                } else {
                    console.warn('[CONFIG] No configuration received, using defaults');
                }
            } catch (err) {
                console.error('[CONFIG] Failed to load trend viewer settings:', err);
                console.warn('[CONFIG] Using default configuration');
            }
        }

        // HIGH-PERFORMANCE: Batched DOM updates using requestAnimationFrame
        let pendingTagUpdates = new Map();
        let rafScheduled = false;

        connection.on("TagValuesUpdated", (values) => {
            // Batch updates instead of immediate DOM manipulation
            values.forEach(tag => {
                pendingTagUpdates.set(tag.itemID, tag);
            });
            
            if (!rafScheduled) {
                rafScheduled = true;
                requestAnimationFrame(() => {
                    flushBatchedUpdates();
                    rafScheduled = false;
                });
            }
            
            // Update trend data (less frequent, already optimized)
            updateTrendData(values);
        });

        // HIGH-PERFORMANCE: Flush batched DOM updates in single animation frame
        function flushBatchedUpdates() {
            if (pendingTagUpdates.size === 0) return;
            
            for (const [itemId, tag] of pendingTagUpdates) {
                updateSingleTag(itemId, tag);
            }
            
            pendingTagUpdates.clear();
        }

        // HIGH-PERFORMANCE: Update single tag (called from batched flush)
        function updateSingleTag(itemId, tag) {
            const safeId = itemId.replace(/[^a-zA-Z0-9]/g, '_');
            
            // Update monitored tag data
            if (monitoredTags[itemId]) {
                monitoredTags[itemId].value = tag.value || '--';
                monitoredTags[itemId].quality = tag.quality || 'Unknown';
                const ts = new Date(tag.timestamp);
                monitoredTags[itemId].timestamp = ts.toLocaleTimeString();
            }
            
            // Update DOM elements efficiently (reuse getElementById results)
            const valueEl = document.getElementById(`value-${safeId}`);
            const qualityEl = document.getElementById(`quality-${safeId}`);
            const timestampEl = document.getElementById(`timestamp-${safeId}`);
            const trendValueEl = document.getElementById(`trend-value-${safeId}`);
            const chartCurrentEl = document.getElementById(`chart-current-${safeId}`);
            
            if (valueEl) valueEl.textContent = tag.value || '--';
            if (qualityEl) {
                qualityEl.textContent = tag.quality || 'Unknown';
                qualityEl.style.color = tag.quality && tag.quality.includes('GOOD') ? '#d4edda' : '#f8d7da';
            }
            if (timestampEl) {
                const ts = new Date(tag.timestamp);
                timestampEl.textContent = ts.toLocaleTimeString();
            }
            if (trendValueEl) trendValueEl.textContent = tag.value || '--';
            if (chartCurrentEl) chartCurrentEl.textContent = tag.value || '--';
        }

        // HIGH-PERFORMANCE: Subscribe to only monitored tags (call when tags change)
        async function updateServerSubscription() {
            const subscribedTags = Object.keys(monitoredTags);
            try {
                await connection.invoke("SubscribeToTags", subscribedTags);
                console.log(`[SUBSCRIPTION] Updated: ${subscribedTags.length} tags`);
            } catch (err) {
                console.error("[SUBSCRIPTION] Failed to update:", err);
            }
        }

