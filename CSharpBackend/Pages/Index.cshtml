            if (!canManageLogging) {
                alert('⚠️ Access Denied: Only Administrator can manage logging');
                return;
            }
            
            if (loggingConfig.selectedTags.length === 0) {
                alert('No tags in logging');
                return;
            }

            if (!confirm(`Remove all ${loggingConfig.selectedTags.length} tags from logging?`)) return;

            for (const tagId of [...loggingConfig.selectedTags]) {
                try {
                    await connection.invoke("RemoveTagFromLogging", tagId);
                } catch (err) {
                    console.error(`Error removing tag ${tagId}:`, err);
                }
            }
            
            loggingConfig.selectedTags = [];
            updateLoggingTagSelection();
            updateLoggingUI();
