        function getRandomColor() {
            const colors = [
                '#FF6B35', '#F7931E', '#FDC830', '#37B34A',
                '#00C9FF', '#0575E6', '#667EEA', '#9D50BB',
                '#E91E63', '#FF4081', '#00BCD4', '#009688',
                '#4CAF50', '#FF5722', '#FF9800', '#3F51B5'
            ];
            return colors[Math.floor(Math.random() * colors.length)];
        }

        function adjustAxisBound(currentValue, targetValue, isMinBound) {
            if (currentValue == null || Number.isNaN(currentValue)) {
                return targetValue;
            }

            const threshold = Math.abs(currentValue) * 0.005;  // Very small threshold for maximum sensitivity

            if (isMinBound && targetValue < (currentValue - threshold)) {
                const delta = targetValue - currentValue;
                return currentValue + delta * AXIS_SMOOTHING;
            }

            if (!isMinBound && targetValue > (currentValue + threshold)) {
                const delta = targetValue - currentValue;
                return currentValue + delta * AXIS_SMOOTHING;
            }

            return currentValue;
        }

