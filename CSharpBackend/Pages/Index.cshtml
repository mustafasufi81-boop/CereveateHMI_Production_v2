    async function savePlcTags() {
        const tbody = document.getElementById('tagEditorBody');
        const rows = tbody.querySelectorAll('tr');
        const tags = [];

        rows.forEach((row, i) => {
            const name = row.querySelector(`input[id^="tagName"]`)?.value?.trim();
            const address = row.querySelector(`input[id^="tagAddr"]`)?.value?.trim();
            const dataType = row.querySelector(`select[id^="tagType"]`)?.value;
            const description = row.querySelector(`input[id^="tagDesc"]`)?.value?.trim();

            if (name) {
                tags.push({
                    name,
                    address: address || name, // Use name as address if not specified
                    dataType: dataType || 'DINT',
                    description
                });
            }
        });

        if (tags.length === 0) {
            alert('Please add at least one tag with a name.');
            return;
        }

        try {
            const response = await fetch(`/api/plc/tags/${currentEditPlcId}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ tags })
            });

            const result = await response.json();
            if (result.success) {
                alert(`✅ ${tags.length} tag(s) saved! Click Connect to start reading data.`);
                closeTagEditorModal();
                await refreshPlcStatus();
            } else {
                alert(`Error: ${result.error}`);
            }
        } catch (error) {
            alert(`Error saving tags: ${error.message}`);
        }
    }

