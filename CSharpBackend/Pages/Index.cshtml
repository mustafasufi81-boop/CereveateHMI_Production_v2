                            <label style="display: block; margin-bottom: 5px; font-weight: 500; color: #333;">New Password:</label>
                            <input type="password" id="newUserPassword" style="width: 100%; padding: 10px; border: 2px solid #ddd; border-radius: 8px; font-size: 1em;" required minlength="6">
                        </div>
                        <div style="margin-bottom: 15px;">
                            <label style="display: block; margin-bottom: 5px; font-weight: 500; color: #333;">Confirm New Password:</label>
                            <input type="password" id="confirmUserPassword" style="width: 100%; padding: 10px; border: 2px solid #ddd; border-radius: 8px; font-size: 1em;" required minlength="6">
