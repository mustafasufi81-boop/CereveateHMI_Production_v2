    async function togglePlcConnection(plcId) {
        const conn = plcConnections.find(c => c.plcId === plcId);
        if (!conn) return;
        
        const action = conn.isConnected ? 'disconnect' : 'connect';
        
        try {
            const response = await fetch(`/api/plc/${action}/${plcId}`, { method: 'POST' });
            if (!response.ok) throw new Error(`Failed to ${action}`);
            
            await refreshPlcStatus();
        } catch (error) {
            alert(`Error: ${error.message}`);
        }
    }

