        function toggleTrendSelection(itemId) {
            if (selectedTrends.has(itemId)) {
                selectedTrends.delete(itemId);
            } else {
                selectedTrends.add(itemId);
            }
            updateTrendList();
        }

        function removeSelectedTrends() {
            if (!isAdmin) {
                alert('⚠️ Access Denied: Only Administrator can manage trends');
                return;
            }
            
            if (selectedTrends.size === 0) {
                alert('Please select trends to remove');
                return;
            }

            if (!confirm(`Remove ${selectedTrends.size} trend(s)?`)) return;

            selectedTrends.forEach(itemId => {
                if (monitoredTags[itemId]) {
                    monitoredTags[itemId].trending = false;
                }
                removeFromTrend(itemId);
            });

            selectedTrends.clear();
            displayMonitoredTags();
            updateTrendList();
            renderAllCharts();
        }

        function clearAllTrends() {
            if (!isAdmin) {
                alert('⚠️ Access Denied: Only Administrator can manage trends');
                return;
            }
            
            const trendingTags = Object.values(monitoredTags).filter(t => t.trending);
            
            if (trendingTags.length === 0) {
                alert('No trends to clear');
                return;
            }

            if (!confirm('Clear all trends?')) return;

            trendingTags.forEach(tag => {
                tag.trending = false;
                removeFromTrend(tag.itemId);
            });

            selectedTrends.clear();
            displayMonitoredTags();
            updateTrendList();
            renderAllCharts();
        }

        function initializeTrend(itemId) {
            if (!monitoredTags[itemId]) return;

            const friendlyName = getFriendlyTagName(itemId);
            trendData[itemId] = {
                itemId: itemId,
                displayName: friendlyName,
                timestamps: [],
                values: [],
                color: getRandomColor(),
                yMin: null,
                yMax: null
            };
        }

        function removeFromTrend(itemId) {
            if (trendCharts[itemId]) {
                trendCharts[itemId].destroy();
                delete trendCharts[itemId];
            }
            delete trendData[itemId];
        }

        function updateTrendData(values) {
            if (!Array.isArray(values)) return;

            const now = new Date();
            
            values.forEach(tag => {
                if (trendData[tag.itemID]) {
                    const trend = trendData[tag.itemID];
                    
                    // Add new data point
                    trend.timestamps.push(now);
                    
                    // Parse numeric value
                    let numericValue = parseFloat(tag.value);
                    if (isNaN(numericValue)) {
                        // Try to convert boolean
                        if (tag.value === 'true' || tag.value === 'True') numericValue = 1;
                        else if (tag.value === 'false' || tag.value === 'False') numericValue = 0;
                        else numericValue = 0;
                    }
                    trend.values.push(numericValue);
                    
                    // Keep only the most recent MAX_TREND_POINTS samples
                    while (trend.timestamps.length > MAX_TREND_POINTS) {
                        trend.timestamps.shift();
                        trend.values.shift();
                    }
                    
                    // Update chart if it exists
                    if (trendCharts[tag.itemID]) {
                        updateChart(tag.itemID);
                    }
                }
            });
        }

        function renderAllCharts() {
            const container = document.getElementById('chartContainer');
            const activeTrends = Object.keys(trendData);
            
            if (activeTrends.length === 0) {
                container.innerHTML = '<p style="color: #999; text-align: center; padding: 40px;">Enable trend checkboxes to start trending</p>';
                return;
            }

            container.innerHTML = activeTrends.map(itemId => {
                const friendlyName = getFriendlyTagName(itemId);
                const showBothNames = friendlyName !== itemId;
                const safeId = itemId.replace(/[^a-zA-Z0-9]/g, '_');
                const trend = trendData[itemId];
                const values = trend.values;
                const avg = values.length > 0 ? (values.reduce((a, b) => a + b, 0) / values.length).toFixed(2) : '--';
                const max = values.length > 0 ? Math.max(...values).toFixed(2) : '--';
                const min = values.length > 0 ? Math.min(...values).toFixed(2) : '--';
                return `
                    <div class="chart-wrapper" style="margin: 20px 0; border-radius: 12px; box-shadow: 0 8px 24px rgba(0,0,0,0.15); overflow: hidden; background: white;">
                        <div class="chart-title" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 20px; border-radius: 0;">
                            <div style="font-size: 1.3em; font-weight: bold; text-shadow: 0 2px 4px rgba(0,0,0,0.2);">📈 ${friendlyName}</div>
                            ${showBothNames ? `<div style="font-size: 0.9em; opacity: 0.95; margin-top: 5px; font-weight: 500;">${itemId}</div>` : ''}
                            <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-top: 12px;">
                                <div style="background: rgba(76, 175, 80, 0.3); padding: 10px; border-radius: 8px; text-align: center;">
                                    <div style="font-size: 0.85em; opacity: 0.9;">Average</div>
                                    <div id="chart-avg-${safeId}" style="font-weight: bold; font-size: 1.2em; margin-top: 4px;">${avg}</div>
                                </div>
                                <div style="background: rgba(244, 67, 54, 0.3); padding: 10px; border-radius: 8px; text-align: center;">
                                    <div style="font-size: 0.85em; opacity: 0.9;">Max</div>
                                    <div id="chart-max-${safeId}" style="font-weight: bold; font-size: 1.2em; margin-top: 4px;">${max}</div>
                                </div>
                                <div style="background: rgba(33, 150, 243, 0.3); padding: 10px; border-radius: 8px; text-align: center;">
                                    <div style="font-size: 0.85em; opacity: 0.9;">Min</div>
                                    <div id="chart-min-${safeId}" style="font-weight: bold; font-size: 1.2em; margin-top: 4px;">${min}</div>
                                </div>
                            </div>
                            <div style="margin-top: 8px; font-size: 0.9em; opacity: 0.95;">Points: <span id="chart-points-${safeId}">${values.length}</span> / ${MAX_TREND_POINTS}</div>
                        </div>
                        <div style="padding: 20px; background: #f5f5f5; border: 1px solid #ddd;">
                            <canvas id="chart-${safeId}" style="height: 350px; min-height: 350px; max-height: 450px; background: #fafafa;"></canvas>
                        </div>
                    </div>
                `;
            }).join('');

            // Create charts
            activeTrends.forEach(itemId => {
                createChart(itemId);
            });
        }

        function createChart(itemId) {
            const safeId = itemId.replace(/[^a-zA-Z0-9]/g, '_');
            const canvas = document.getElementById(`chart-${safeId}`);
            if (!canvas) return;

            const ctx = canvas.getContext('2d');
            const trend = trendData[itemId];

            if (trendCharts[itemId]) {
                trendCharts[itemId].destroy();
            }

            // Initialize y-axis bounds from initial data
            if (trend.values && trend.values.length > 0) {
                const minVal = Math.min(...trend.values);
                const maxVal = Math.max(...trend.values);
                const range = Math.max(1e-6, Math.abs(maxVal - minVal));
                const pad = Math.max(1, range * 0.15);
                trend.yMin = minVal - pad;
                trend.yMax = maxVal + pad;
            }

            trendCharts[itemId] = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: trend.timestamps.map(t => t.toLocaleTimeString()),
                    datasets: [{
                        label: trend.displayName,
                        data: trend.values,
                        borderColor: trend.color || '#FF6B35',
                        backgroundColor: 'transparent',
                        borderWidth: 3,
                        tension: 0,
                        fill: false,
                        pointRadius: 0,
                        pointHoverRadius: 5,
                        pointBackgroundColor: '#fff',
                        pointBorderColor: trend.color || '#FF6B35',
                        pointBorderWidth: 2,
                        pointHoverBackgroundColor: trend.color || '#FF6B35',
                        pointHoverBorderColor: '#fff',
                        pointHoverBorderWidth: 2,
                        spanGaps: true
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    animation: {
                        duration: 0
                    },
                    parsing: true,
                    interaction: {
                        mode: 'nearest',
                        intersect: false
                    },
                    scales: {
                        x: {
                            type: 'category',
                            display: true,
                            title: {
                                display: true,
                                text: 'Time',
                                color: '#1a1a1a',
                                font: { size: 13, weight: '600', family: 'Arial' }
                            },
                            ticks: {
                                maxTicksLimit: 25,
                                autoSkip: true,
                                maxRotation: 45,
                                minRotation: 0,
                                color: '#333',
                                font: { size: 10, family: 'Arial' }
                            },
                            grid: {
                                display: true,
                                color: '#e6e6e6',
                                drawBorder: true,
                                drawOnChartArea: true,
                                drawTicks: true
                            }
                        },
                        y: {
                            type: 'linear',
                            display: true,
                            position: 'left',
                            title: {
                                display: true,
                                text: 'Process Value',
                                color: '#1a1a1a',
                                font: { size: 13, weight: '600', family: 'Arial' }
                            },
                            ticks: {
                                color: '#333',
                                font: { size: 11, family: 'Arial' },
                                callback: function(value) {
                                    return value.toFixed(2);
                                }
                            },
                            grid: {
                                display: true,
                                color: function(context) {
                                    if (context.tick.value === 0) {
                                        return '#666';
                                    }
                                    return '#e6e6e6';
                                },
                                lineWidth: function(context) {
                                    if (context.tick.value === 0) {
                                        return 2;
                                    }
                                    return 1;
                                },
                                drawBorder: true,
                                drawOnChartArea: true,
                                drawTicks: true
                            },
                            beginAtZero: false,
                            min: trend.yMin,
                            max: trend.yMax
                        }
                    },
                    plugins: {
                        decimation: { enabled: false },
                        legend: {
                            display: true,
                            position: 'top',
                            align: 'start',
                            labels: {
                                color: '#1a1a1a',
                                font: { size: 12, weight: '600', family: 'Arial' },
                                padding: 15,
                                usePointStyle: true,
                                pointStyle: 'line',
                                boxWidth: 40,
                                boxHeight: 3,
                                generateLabels: function(chart) {
                                    const datasets = chart.data.datasets;
                                    return datasets.map((dataset, i) => ({
                                        text: dataset.label + ' = ' + (trend.values[trend.values.length - 1] || 0).toFixed(2),
                                        fillStyle: dataset.borderColor,
                                        strokeStyle: dataset.borderColor,
                                        lineWidth: 3,
                                        hidden: false,
                                        index: i
                                    }));
                                }
                            }
                        },
                        tooltip: {
                            enabled: true,
                            mode: 'nearest',
                            intersect: false,
                            backgroundColor: 'rgba(44, 62, 80, 0.95)',
                            titleColor: '#fff',
                            titleFont: { size: 14, weight: 'bold', family: 'Segoe UI' },
                            bodyColor: '#fff',
                            bodyFont: { size: 13, family: 'Segoe UI' },
                            borderColor: trend.color,
                            borderWidth: 3,
                            padding: 15,
                            displayColors: true,
                            callbacks: {
                                label: function(context) {
                                    let label = context.dataset.label || '';
                                    if (label) {
                                        label += ': ';
                                    }
                                    if (context.parsed.y !== null) {
                                        label += context.parsed.y.toLocaleString();
                                    }
                                    return label;
                                }
                            }
                        }
                    }
                }
            });
        }

        function updateChart(itemId) {
            // HIGH-PERFORMANCE: Batch chart updates (2s debounce)
            if (chartBatcher) {
                chartBatcher.requestUpdate(itemId);
                return;
            }
            
            // FALLBACK: Immediate update
            updateChartImmediate(itemId);
        }
        
        // HIGH-PERFORMANCE: Immediate chart update (called by batcher or fallback)
        function updateChartImmediate(itemId) {
            const chart = trendCharts[itemId];
            if (!chart) return;

            const trend = trendData[itemId];
            if (!trend) return;
            chart.data.labels = trend.timestamps.map(t => t.toLocaleTimeString());
            chart.data.datasets[0].data = trend.values;
            
            // Use Web Worker for stats calculation if available
            if (trendWorker && trend.values && trend.values.length > 0) {
                trendWorker.calculateStats(itemId, trend.values, (stats) => {
                    const latestTrend = trendData[itemId];
                    if (!stats || !latestTrend) return;

                    latestTrend.yMin = adjustAxisBound(latestTrend.yMin, stats.yMin, true);
                    latestTrend.yMax = adjustAxisBound(latestTrend.yMax, stats.yMax, false);

                    if (chart.options && chart.options.scales && chart.options.scales.y) {
                        chart.options.scales.y.min = latestTrend.yMin;
                        chart.options.scales.y.max = latestTrend.yMax;
                    }

                    const safeId = itemId.replace(/[^a-zA-Z0-9]/g, '_');
                    const avgEl = document.getElementById(`chart-avg-${safeId}`);
                    const maxEl = document.getElementById(`chart-max-${safeId}`);
                    const minEl = document.getElementById(`chart-min-${safeId}`);
                    const ptsEl = document.getElementById(`chart-points-${safeId}`);

                    if (avgEl) avgEl.textContent = stats.avg;
                    if (maxEl) maxEl.textContent = stats.max;
                    if (minEl) minEl.textContent = stats.min;
                    if (ptsEl) ptsEl.textContent = stats.count;
                });
            } else {
                // FALLBACK: Inline calculation (original logic)
                if (trend.values && trend.values.length > 0) {
                    const minVal = Math.min(...trend.values);
                    const maxVal = Math.max(...trend.values);
                    const range = Math.max(1e-6, Math.abs(maxVal - minVal));
                    const pad = Math.max(1, range * 0.1);

                    const targetMin = minVal - pad;
                    const targetMax = maxVal + pad;

                    trend.yMin = adjustAxisBound(trend.yMin, targetMin, true);
                    trend.yMax = adjustAxisBound(trend.yMax, targetMax, false);

                    if (chart.options && chart.options.scales && chart.options.scales.y) {
                        chart.options.scales.y.min = trend.yMin;
                        chart.options.scales.y.max = trend.yMax;
                    }
                }
                // Update points count badge
                const safeId = itemId.replace(/[^a-zA-Z0-9]/g, '_');
                const ptsEl = document.getElementById(`chart-points-${safeId}`);
                if (ptsEl) ptsEl.textContent = trend.values.length;
                
                // Update statistics
                const values = trend.values;
                if (values.length > 0) {
                    const avg = (values.reduce((a, b) => a + b, 0) / values.length).toFixed(2);
                    const max = Math.max(...values).toFixed(2);
                    const min = Math.min(...values).toFixed(2);
                    
                    const avgEl = document.getElementById(`chart-avg-${safeId}`);
                    const maxEl = document.getElementById(`chart-max-${safeId}`);
                    const minEl = document.getElementById(`chart-min-${safeId}`);
                    
                    if (avgEl) avgEl.textContent = avg;
                    if (maxEl) maxEl.textContent = max;
                    if (minEl) minEl.textContent = min;
                }
            }
            
            chart.update('none');
        }

