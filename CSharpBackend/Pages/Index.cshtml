        function getHistTimeRange() {
            const startVal = document.getElementById('histStart').value;
            const endVal = document.getElementById('histEnd').value;
            if (!startVal || !endVal) return null;
            return { start: new Date(startVal), end: new Date(endVal) };
        }

        async function loadHistorianTrends() {
            const tagIds = Array.from(histSelectedTags);
            if (tagIds.length === 0) {
                alert('Select at least one tag');
                return;
            }

            const range = getHistTimeRange();
            if (!range) {
                alert('Set start/end time');
                return;
            }

            const maxPoints = parseInt(document.getElementById('histMaxPoints').value || '1000', 10);
            const source = document.getElementById('histSourceSelect').value || null;

            const payload = {
                tagIds,
                startTime: range.start.toISOString(),
                endTime: range.end.toISOString(),
                maxPoints: isNaN(maxPoints) ? 1000 : maxPoints,
                sampleSource: source
            };

            try {
                const res = await fetch('/api/historian-browser/trends', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                const json = await res.json();
                if (json.success) {
                    renderHistorianChart(json.data || {}, source);
                } else {
                    alert('Failed to load trends: ' + json.error);
                }
            } catch (err) {
                console.error('Historian trend error', err);
                alert('Failed to load historian trends');
            }
        }

