        function displayTags(tags) {
            const tree = document.getElementById("tagTree");
            if (!tags || tags.length === 0) {
                tree.innerHTML = '<p style="color: #999;">No tags available</p>';
                document.getElementById("tagCount").textContent = "(0 tags)";
                return;
            }

            // Build tree structure
            const treeStructure = buildTreeStructure(tags);
            tree.innerHTML = renderTree(treeStructure);
            
            document.getElementById("tagCount").textContent = `(${tags.length} tags)`;
            
            // Clear search input when new tags are loaded
            const searchInput = document.getElementById("tagSearchInput");
            if (searchInput) {
                searchInput.value = '';
            }
        }

        function buildTreeStructure(tags) {
            const root = { children: {}, tags: [] };
            
            tags.forEach(tag => {
                if (tag.isFolder) {
                    // Skip folders, we'll build them from paths
                    return;
                }
                
                const path = tag.path || '';
                const parts = path ? path.split('.') : [];
                
                let current = root;
                parts.forEach(part => {
                    if (!current.children[part]) {
                        current.children[part] = { children: {}, tags: [] };
                    }
                    current = current.children[part];
                });
                
                current.tags.push(tag);
            });
            
            return root;
        }

        function renderTree(node, level = 0) {
            let html = '';
            
            // Render folders
            Object.keys(node.children).sort().forEach(folderName => {
                const childNode = node.children[folderName];
                const folderId = 'folder_' + folderName.replace(/[^a-zA-Z0-9]/g, '_') + '_' + level + '_' + Math.random().toString(36).substr(2, 9);
                
                html += `
                    <div class="tree-node folder collapsed" onclick="toggleFolder('${folderId}', this)">
                        <span class="folder-icon">▼</span>
                        ${folderName}
                    </div>
                    <div class="tree-children tree-folder" id="${folderId}">
                        ${renderTree(childNode, level + 1)}
                    </div>
                `;
            });
            
            // Render tags
            node.tags.sort((a, b) => (a.name || a.itemID).localeCompare(b.name || b.itemID)).forEach(tag => {
                const safeId = tag.itemID.replace(/[^a-zA-Z0-9]/g, '_');
                const friendlyName = getFriendlyTagName(tag.itemID);
                const showBothNames = friendlyName !== tag.itemID;
                html += `
                    <div class="tree-node leaf" style="position: relative; display: flex; align-items: flex-start; gap: 8px; cursor: default;">
                        <input type="checkbox" class="available-tag-checkbox" data-tag-id="${tag.itemID}" data-tag-name="${tag.name || tag.itemID}" 
                               style="width: 18px; height: 18px; margin-top: 4px; cursor: pointer; flex-shrink: 0;"
                               onclick="event.stopPropagation()">
                        <div onclick="addTagToMonitor('${tag.itemID}', '${tag.name || tag.itemID}')" style="flex: 1; cursor: pointer;">
                            <strong>${friendlyName}</strong>
                            ${showBothNames ? `<br><small style="color: #999;">${tag.itemID}</small>` : ''}
                            ${tag.dataType ? `<br><small style="color: #666;">${tag.dataType}</small>` : ''}
                        </div>
                    </div>
                `;
            });
            
            return html;
        }

        function toggleFolder(folderId, folderNode) {
            event.stopPropagation();
            const folder = document.getElementById(folderId);
            if (folder) {
                folder.classList.toggle('expanded');
                folderNode.classList.toggle('collapsed');
            }
        }

        function filterTags(searchText) {
            const tree = document.getElementById("tagTree");
            const allNodes = tree.querySelectorAll('.tree-node');
            const searchLower = searchText.toLowerCase().trim();
            
            if (!searchLower) {
                // Show all nodes when search is empty
                allNodes.forEach(node => {
                    node.style.display = '';
                });
                // Reset all folders to collapsed
                const folders = tree.querySelectorAll('.tree-node.folder');
                folders.forEach(folder => {
                    folder.classList.add('collapsed');
                });
                const folderContents = tree.querySelectorAll('.tree-folder');
                folderContents.forEach(fc => {
                    fc.classList.remove('expanded');
                });
                return;
            }
            
            // First hide everything
            allNodes.forEach(node => {
                node.style.display = 'none';
            });
            
            // Find matching leaf nodes
            const leafNodes = tree.querySelectorAll('.tree-node.leaf');
            let matchCount = 0;
            
            leafNodes.forEach(leaf => {
                const text = leaf.textContent.toLowerCase();
                if (text.includes(searchLower)) {
                    // Show the matching leaf
                    leaf.style.display = '';
                    matchCount++;
                    
                    // Show all parent folders
                    let parent = leaf.parentElement;
                    while (parent && parent !== tree) {
                        if (parent.classList.contains('tree-folder')) {
                            parent.style.display = '';
                            parent.classList.add('expanded');
                            // Find the corresponding folder node
                            const folderId = parent.id;
                            const folderNode = tree.querySelector(`[onclick*="${folderId}"]`);
                            if (folderNode) {
                                folderNode.style.display = '';
                                folderNode.classList.remove('collapsed');
                            }
                        }
                        parent = parent.parentElement;
                    }
                }
            });
            
            // Update tag count with filtered results
            const totalTags = leafNodes.length;
            const tagCountElement = document.getElementById("tagCount");
            if (searchLower) {
                tagCountElement.textContent = `(${matchCount} of ${totalTags} tags)`;
            } else {
                tagCountElement.textContent = `(${totalTags} tags)`;
            }
        }

        async function addTagToMonitor(itemId, displayName) {
            if (!isAdmin) {
                alert('⚠️ Access Denied: Only Administrator can add/remove tags');
                return;
            }
            
            if (monitoredTags[itemId]) {
                return; // Already monitoring
            }
            
            try {
                await connection.invoke("AddTagToMonitor", itemId, displayName);
                monitoredTags[itemId] = { 
                    itemId, 
                    displayName,
                    trending: false,
                    value: '--',
                    quality: 'Waiting...',
                    timestamp: '--'
                };
                displayMonitoredTags();
                
                // HIGH-PERFORMANCE: Update server subscription
                await updateServerSubscription();
            } catch (err) {
                console.error("Add tag error:", err);
                alert(`Failed to add tag: ${err.message}`);
            }
        }

        function displayMonitoredTags() {
            // HIGH-PERFORMANCE: Use virtual DOM if available, fallback to innerHTML
            if (virtualTagGrid) {
                virtualTagGrid.update(monitoredTags);
                return;
            }
            
            // FALLBACK: Original innerHTML rebuild (for compatibility)
            const container = document.getElementById("valueCards");
            const tags = Object.values(monitoredTags);
            
            document.getElementById("monitoredCount").textContent = tags.length;
            
            if (tags.length === 0) {
                container.innerHTML = '<p style="color: #999;">Click on tags to monitor them</p>';
                return;
            }

            container.innerHTML = tags.map(tag => {
                const safeId = tag.itemId.replace(/[^a-zA-Z0-9]/g, '_');
                const friendlyName = getFriendlyTagName(tag.itemId);
                const showBothNames = friendlyName !== tag.itemId;
                return `
                    <div class="value-card value-card-with-trend">
                        <div class="trend-checkbox-container">
                            <input type="checkbox" 
                                   id="trend_${safeId}" 
                                   ${tag.trending ? 'checked' : ''}
                                   onchange="toggleTrend('${tag.itemId}')">
                            <label for="trend_${safeId}">Trend</label>
                        </div>
                        <div class="card-title">
                            ${friendlyName}
                            ${showBothNames ? `<br><small style="color: #999; font-weight: normal;">${tag.itemId}</small>` : ''}
                        </div>
                        <div class="card-value" id="value-${safeId}">${tag.value}</div>
                        <div class="card-footer">
                            <span id="quality-${safeId}">${tag.quality}</span>
                            <span id="timestamp-${safeId}">${tag.timestamp}</span>
                        </div>
                        ${isAdmin ? `<button class="btn btn-sm btn-danger" style="margin-top: 10px; width: 100%;" 
                                onclick="removeSingleTag('${tag.itemId}')">Remove</button>` : ''}
                    </div>
                `;
            }).join('');
        }

        async function removeSingleTag(itemId) {
            if (!isAdmin) {
                alert('⚠️ Access Denied: Only Administrator can add/remove tags');
                return;
            }
            try {
                await connection.invoke("RemoveTagFromMonitor", itemId);
                removeFromTrend(itemId);
                delete monitoredTags[itemId];
                displayMonitoredTags();
                updateTrendList();
                
                // HIGH-PERFORMANCE: Update server subscription
                await updateServerSubscription();
            } catch (err) {
                console.error(`Failed to remove tag:`, err);
            }
        }

        async function removeAllMonitoredTags() {
            if (!isAdmin) {
                alert('⚠️ Access Denied: Only Administrator can add/remove tags');
                return;
            }
            
            if (Object.keys(monitoredTags).length === 0) {
                alert('No tags to remove');
                return;
            }

            if (!confirm('Remove all monitored tags?')) return;

            for (const tag of Object.values(monitoredTags)) {
                try {
                    await connection.invoke("RemoveTagFromMonitor", tag.itemId);
                    removeFromTrend(tag.itemId);
                } catch (err) {
                    console.error(`Failed to remove tag ${tag.displayName}:`, err);
                }
            }
            
            monitoredTags = {};
            displayMonitoredTags();
            updateTrendList();
            
            // HIGH-PERFORMANCE: Update server subscription
            await updateServerSubscription();
        }

        // ============ AVAILABLE TAGS SELECTION FUNCTIONS ============
        
        function selectAllAvailableTags() {
            const checkboxes = document.querySelectorAll('.available-tag-checkbox');
            checkboxes.forEach(cb => cb.checked = true);
        }

        function deselectAllAvailableTags() {
            const checkboxes = document.querySelectorAll('.available-tag-checkbox');
            checkboxes.forEach(cb => cb.checked = false);
        }

        async function addSelectedTags() {
            if (!isAdmin) {
                alert('⚠️ Access Denied: Only Administrator can add/remove tags');
                return;
            }

            const checkboxes = document.querySelectorAll('.available-tag-checkbox:checked');
            
            if (checkboxes.length === 0) {
                alert('Please select at least one tag');
                return;
            }

            let addedCount = 0;
            let skippedCount = 0;

            for (const checkbox of checkboxes) {
                const itemId = checkbox.dataset.tagId;
                const displayName = checkbox.dataset.tagName;

                if (monitoredTags[itemId]) {
                    skippedCount++;
                    continue;
                }

                try {
                    await connection.invoke("AddTagToMonitor", itemId, displayName);
                    monitoredTags[itemId] = { 
                        itemId, 
                        displayName,
                        trending: false,
                        value: '--',
                        quality: 'Waiting...',
                        timestamp: '--'
                    };
                    checkbox.checked = false;
                    addedCount++;
                } catch (err) {
                    console.error(`Failed to add tag ${displayName}:`, err);
                }
            }

            displayMonitoredTags();
            
            // HIGH-PERFORMANCE: Update server subscription after batch add
            await updateServerSubscription();
            
            if (addedCount > 0) {
                updateStatus(`Added ${addedCount} tag(s) to monitoring${skippedCount > 0 ? ` (${skippedCount} already monitored)` : ''}`, "connected");
            } else if (skippedCount > 0) {
                alert(`All selected tags are already being monitored`);
            }
        }

        // ============ END AVAILABLE TAGS SELECTION FUNCTIONS ============

        function toggleTrend(itemId) {
            if (!isAdmin) {
                alert('⚠️ Access Denied: Only Administrator can manage trends');
                return;
            }
            
            const tag = monitoredTags[itemId];
            if (!tag) return;
            
            tag.trending = !tag.trending;
            
            if (tag.trending) {
                initializeTrend(itemId);
                // HIGH-PERFORMANCE: Force immediate chart update for user interaction
                if (chartBatcher) {
                    chartBatcher.forceUpdate(itemId);
                }
            } else {
                removeFromTrend(itemId);
                selectedTrends.delete(itemId);
            }
            
            updateTrendList();
            renderAllCharts();
        }

        // DEPRECATED: Old synchronous update function replaced by batched updates
        // Kept for backward compatibility but now just queues updates
        function updateTagValues(values) {
            if (!Array.isArray(values)) return;
            
            values.forEach(tag => {
                pendingTagUpdates.set(tag.itemID, tag);
            });
            
            if (!rafScheduled) {
                rafScheduled = true;
                requestAnimationFrame(() => {
                    flushBatchedUpdates();
                    rafScheduled = false;
                });
            }
        }

        function updateStatus(message, status) {
            const label = document.getElementById("statusLabel");
            label.textContent = message;
            label.className = `status ${status}`;
        }

        // ============ TRENDING FUNCTIONS ============
        
        function updateTrendList() {
            const container = document.getElementById("trendList");
            const activeTrends = Object.values(monitoredTags).filter(t => t.trending);
            
            document.getElementById("trendCount").textContent = activeTrends.length;
            
            if (activeTrends.length === 0) {
                container.innerHTML = '<p style="color: #999;">Enable trend checkboxes in Monitoring tab to see trends here</p>';
                return;
            }

            container.innerHTML = activeTrends.map(tag => {
                const safeId = tag.itemId.replace(/[^a-zA-Z0-9]/g, '_');
                const friendlyName = getFriendlyTagName(tag.itemId);
                const showBothNames = friendlyName !== tag.itemId;
                return `
                    <div class="trend-item ${selectedTrends.has(tag.itemId) ? 'selected' : ''}" 
                         onclick="toggleTrendSelection('${tag.itemId}')">
                        <div>
                            <strong>${friendlyName}</strong>
                            ${showBothNames ? `<br><small style="color: #999;">${tag.itemId}</small>` : ''}
                            <br><small style="color: #666;">Current: <span id="trend-value-${safeId}">${tag.value}</span></small>
                        </div>
