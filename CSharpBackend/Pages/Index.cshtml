    function addTagRow() {
        const tbody = document.getElementById('tagEditorBody');
        const index = tbody.children.length;
        const tr = document.createElement('tr');
        tr.id = `tagRow_${index}`;
        tr.innerHTML = renderTagRow(index, { name: '', address: '', dataType: 'DINT', description: '' }).replace(/<tr[^>]*>|<\/tr>/g, '');
        tbody.appendChild(tr);
