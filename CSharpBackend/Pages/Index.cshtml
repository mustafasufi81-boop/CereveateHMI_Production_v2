    function renderUaTrends(data) {
        const container = document.getElementById('uaTrendsContainer');
        container.innerHTML = '';

        Object.entries(data).forEach(([tagId, points]) => {
            const displayName = uaDisplayNameMap.get(tagId) || tagId;
            
            const chartDiv = document.createElement('div');
            chartDiv.style.cssText = 'margin-bottom: 30px; padding: 20px; background: white; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);';
            
            const title = document.createElement('h4');
            title.textContent = `${displayName}`;
            title.style.cssText = 'margin: 0 0 15px 0; color: #1e3c72; font-size: 1.1em;';
            chartDiv.appendChild(title);

            if (points.length === 0) {
                chartDiv.innerHTML += '<p style="color: #999; text-align: center; padding: 40px;">No data in last 24h</p>';
            } else {
                const canvas = document.createElement('canvas');
                // Let renderMiniChart size the canvas responsively
                canvas.style.width = '100%';
                canvas.style.height = '320px';
                chartDiv.appendChild(canvas);

                renderMiniChart(canvas, points, displayName);
            }

            container.appendChild(chartDiv);
        });
    }

    function renderMiniChart(canvas, points, label) {
        const ctx = canvas.getContext('2d');
        const dpr = window.devicePixelRatio || 1;
        const parentWidth = canvas.parentElement ? canvas.parentElement.clientWidth : 800;
        const logicalWidth = parentWidth || 800;
        const logicalHeight = 320;
        const padding = 40;

        // Resize canvas to parent width with high-DPI support to avoid shrinking/blur
        canvas.style.width = '100%';
        canvas.style.height = `${logicalHeight}px`;
        canvas.width = Math.round(logicalWidth * dpr);
        canvas.height = Math.round(logicalHeight * dpr);

        // Reset transform and scale for device pixel ratio
        ctx.setTransform(1, 0, 0, 1, 0, 0);
        ctx.scale(dpr, dpr);

        // Use logical dimensions for drawing math
        const width = logicalWidth;
        const height = logicalHeight;

        ctx.clearRect(0, 0, width, height);

        if (points.length < 2) return;

        const values = points.map(p => parseFloat(p.value) || 0);
        const minVal = Math.min(...values);
        const maxVal = Math.max(...values);
        const range = maxVal - minVal || 1;

        // Grid
        ctx.strokeStyle = '#e0e0e0';
        ctx.lineWidth = 1;
        for (let i = 0; i <= 5; i++) {
            const y = padding + (height - 2 * padding) * i / 5;
            ctx.beginPath();
            ctx.moveTo(padding, y);
            ctx.lineTo(width - padding, y);
            ctx.stroke();
        }

        // Line
        ctx.strokeStyle = '#667eea';
        ctx.lineWidth = 2;
        ctx.beginPath();

        points.forEach((point, idx) => {
            const x = padding + (width - 2 * padding) * idx / (points.length - 1);
            const val = parseFloat(point.value) || 0;
            const y = height - padding - ((val - minVal) / range) * (height - 2 * padding);

            if (idx === 0) ctx.moveTo(x, y);
            else ctx.lineTo(x, y);
        });

        ctx.stroke();

        // Labels
        ctx.fillStyle = '#333';
        ctx.font = '12px Arial';
        ctx.fillText(`Min: ${minVal.toFixed(2)}`, padding, height - 10);
        ctx.fillText(`Max: ${maxVal.toFixed(2)}`, width - padding - 80, height - 10);
        ctx.fillText(`Points: ${points.length}`, width / 2 - 30, height - 10);
    }

