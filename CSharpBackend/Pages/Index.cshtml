        </div>
    </div>
    
    <script>
    // ========== OPC UA Functions ==========
    let uaBrowsedTags = [];
    let uaSelectedTags = new Set();
    let uaStatusInterval = null;
    const uaDisplayNameMap = new Map(); // nodeId -> friendly display name

    async function connectOpcUa() {
        const endpoint = document.getElementById('uaEndpointInput').value.trim();
        if (!endpoint) {
            alert('Please enter an endpoint');
            return;
        }

        try {
            const response = await fetch('/api/opcua/connect', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ endpoint })
            });
            
            const result = await response.json();
            
            if (result.success) {
                alert('✅ Connected to OPC UA server!');
                updateUaStatus();
                if (!uaStatusInterval) {
                    uaStatusInterval = setInterval(updateUaStatus, 2000);
                }
            } else {
                alert('❌ Connection failed: ' + result.error);
            }
        } catch (error) {
            alert('❌ Error: ' + error.message);
        }
    }

    async function disconnectOpcUa() {
        try {
            const response = await fetch('/api/opcua/disconnect', { method: 'POST' });
            const result = await response.json();
            
            if (result.success) {
                alert('✅ Disconnected');
                if (uaStatusInterval) {
                    clearInterval(uaStatusInterval);
                    uaStatusInterval = null;
                }
                updateUaStatus();
                document.getElementById('uaBrowsePanel').style.display = 'none';
                document.getElementById('uaMonitoringPanel').style.display = 'none';
            }
        } catch (error) {
            alert('❌ Error: ' + error.message);
        }
    }

    async function browseOpcUaTags() {
        try {
            const response = await fetch('/api/opcua/browse-detailed');
            const result = await response.json();
            
            if (!result.success) {
                alert('❌ Browse failed: ' + result.error);
                return;
            }

            uaSelectedTags.clear();
            uaDisplayNameMap.clear();

            uaBrowsedTags = (result.tags || []).map(tag => {
                const nodeId = (tag.nodeId || tag.NodeId || '').toString();
                const displayName = (tag.displayName || tag.DisplayName || nodeId).toString();
                return { nodeId, displayName };
            });

            uaBrowsedTags.forEach(t => uaDisplayNameMap.set(t.nodeId, t.displayName));
            
            const listDiv = document.getElementById('uaTagList');
            if (!uaBrowsedTags.length) {
                listDiv.innerHTML = '<div style="padding:12px; color:#888; text-align:center;">No tags returned. Ensure the server is connected and exposes namespace > 0.</div>';
            } else {
                listDiv.innerHTML = uaBrowsedTags.map(tag => `
                    <div class="ua-tag-item" data-display-name="${tag.displayName?.toLowerCase()}" data-node-id="${tag.nodeId.toLowerCase()}" style="padding: 8px; border-bottom: 1px solid #dee2e6; display: flex; align-items: center; gap: 10px;">
                        <input type="checkbox" class="ua-tag-checkbox" value="${tag.nodeId}" onchange="toggleUaTag(this.value)">
                        <div style="display:flex; flex-direction:column;">
                            <span style="font-weight:600;">${tag.displayName}</span>
                            <span style="font-family: monospace; font-size: 0.85em; color:#555;">${tag.nodeId}</span>
                        </div>
                    </div>
                `).join('');
            }
            
            document.getElementById('uaBrowsePanel').style.display = 'block';
            updateUaSelectedCount();
        } catch (error) {
            alert('❌ Error: ' + error.message);
        }
    }

    function toggleUaTag(tagId) {
        if (uaSelectedTags.has(tagId)) {
            uaSelectedTags.delete(tagId);
        } else {
            uaSelectedTags.add(tagId);
        }
        updateUaSelectedCount();
    }

    function updateUaSelectedCount() {
        document.getElementById('uaSelectedCount').textContent = uaSelectedTags.size + ' tags selected';
    }

    function filterUaTags() {
        const filter = document.getElementById('uaTagFilter').value.toLowerCase();
        const items = document.querySelectorAll('.ua-tag-item');
        items.forEach(item => {
            const displayName = item.dataset.displayName || '';
            const nodeId = item.dataset.nodeId || '';
            item.style.display = (displayName.includes(filter) || nodeId.includes(filter)) ? 'flex' : 'none';
        });
    }

    async function startUaMonitoring() {
        if (uaSelectedTags.size === 0) {
            alert('Please select at least one tag');
            return;
        }

        const intervalMs = parseInt(document.getElementById('uaPollingInterval').value);
        
        try {
            const response = await fetch('/api/opcua/monitor', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    tagIds: Array.from(uaSelectedTags),
                    intervalMs
                })
            });
            
            const result = await response.json();
            
            if (result.success) {
                alert('✅ Monitoring started for ' + result.tagCount + ' tags');
                document.getElementById('uaMonitoringPanel').style.display = 'block';
                startUaValuePolling();
                // Load historical trends
                setTimeout(() => refreshUaTrends(), 2000);
            } else {
                alert('❌ Failed: ' + result.error);
            }
        } catch (error) {
            alert('❌ Error: ' + error.message);
        }
    }

    let uaValuePollingInterval = null;

    function startUaValuePolling() {
        if (uaValuePollingInterval) {
            clearInterval(uaValuePollingInterval);
        }
        
        updateUaValues();
        uaValuePollingInterval = setInterval(updateUaValues, 2000);
    }

    async function updateUaValues() {
        try {
            const response = await fetch('/api/opcua/values', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ tagIds: Array.from(uaSelectedTags) })
            });
            
            const result = await response.json();
            
            if (result.success) {
                const container = document.getElementById('uaLiveValues');
                container.innerHTML = Object.entries(result.values).map(([tagId, value]) => {
                    const displayName = uaDisplayNameMap.get(tagId) || tagId;
                    return `
                        <div class="value-card" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
                            <div class="card-title" style="color: white; opacity: 0.9; font-size: 0.85em; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="${tagId}">${displayName}</div>
                            <div class="card-value" style="color: white;">${value !== null && value !== undefined ? value : 'null'}</div>
                            <div style="font-size: 0.75em; opacity: 0.8; font-family: monospace;">${tagId}</div>
                        </div>
                    `;
                }).join('');
            }
        } catch (error) {
            console.error('Failed to update UA values:', error);
        }
    }

    async function updateUaStatus() {
        try {
            const response = await fetch('/api/opcua/status');
            const result = await response.json();
            
            if (result.success) {
                document.getElementById('uaStatusText').textContent = result.isConnected ? '✅ Connected' : '❌ Disconnected';
                document.getElementById('uaEndpoint').textContent = result.endpoint || '-';
                document.getElementById('uaMonitoredCount').textContent = result.monitoredTags;
                document.getElementById('uaSamplesWritten').textContent = result.performance.samplesWritten;
            }
        } catch (error) {
            console.error('Failed to get UA status:', error);
        }
    }

    // ========== OPC UA Trends from DB ==========
    async function refreshUaTrends() {
        if (uaSelectedTags.size === 0) {
            alert('Select tags first');
            return;
        }

        const endTime = new Date();
        const startTime = new Date(endTime - 24 * 60 * 60 * 1000); // 24h ago

        try {
            const response = await fetch('/api/opcua-historian/trends', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    tagIds: Array.from(uaSelectedTags),
                    startTime: startTime.toISOString(),
