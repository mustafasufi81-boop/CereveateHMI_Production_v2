        const tbody = document.getElementById('plcConnectionsBody');
        
        if (plcConnections.length === 0) {
            tbody.innerHTML = '<tr><td colspan="9" style="text-align:center; color:#7f8c8d;">No PLC connections configured. Add a PLC to get started.</td></tr>';
            return;
        }
        
        tbody.innerHTML = plcConnections.map(conn => `
            <tr>
                <td>
                    <span class="status-badge ${conn.isConnected ? 'connected' : 'disconnected'}">
                        ${conn.isConnected ? '🟢 Connected' : '🔴 Disconnected'}
                    </span>
                </td>
                <td><code>${conn.plcId || 'N/A'}</code></td>
                <td>${conn.name || conn.plcId || 'Unknown'}</td>
                <td><span class="protocol-badge">${conn.protocol || 'Unknown'}</span></td>
                <td>${conn.ipAddress || conn.host || 'N/A'}</td>
                <td>${conn.port || 'N/A'}</td>
                <td><a href="#" onclick="browsePlcTags('${conn.plcId}'); return false;" style="color:#3498db; text-decoration:underline; cursor:pointer;">${conn.tagCount || 0}</a></td>
                <td>${conn.lastUpdate ? new Date(conn.lastUpdate).toLocaleString() : 'Never'}</td>
                <td>
                    <button class="btn btn-sm btn-info" onclick="browsePlcTags('${conn.plcId}')" title="Browse PLC Memory / Select Tags">🔍</button>
                    <button class="btn btn-sm btn-secondary" onclick="testPlcConnection('${conn.plcId}')" title="Test Connection">🔧</button>
                    <button class="btn btn-sm ${conn.isConnected ? 'btn-warning' : 'btn-success'}" 
