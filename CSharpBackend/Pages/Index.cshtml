                        <div style="margin-bottom: 15px;">
                            <label style="display: block; margin-bottom: 5px; font-weight: bold;">Display Name</label>
                            <input type="text" id="newPlcName" style="width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 4px;" placeholder="e.g., Main Production PLC">
                        </div>
                        
                        <div style="margin-bottom: 15px;">
                            <label style="display: block; margin-bottom: 5px; font-weight: bold;">Protocol *</label>
                            <select id="newPlcProtocol" required style="width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 4px;">
                                <option value="">Select Protocol...</option>
                                <option value="S7">Siemens S7 (S7-300/400/1200/1500)</option>
                                <option value="ModbusTcp">Modbus TCP</option>
                                <option value="EtherNetIP">Rockwell EtherNet/IP</option>
                                <option value="ABB">ABB AC500</option>
                                <option value="Mitsubishi">Mitsubishi MELSEC</option>
                                <option value="Omron">Omron FINS</option>
                            </select>
                        </div>
                        
                        <div style="margin-bottom: 15px;">
                            <label style="display: block; margin-bottom: 5px; font-weight: bold;">IP Address *</label>
                            <input type="text" id="newPlcIp" required style="width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 4px;" placeholder="e.g., 192.168.1.100">
                        </div>
                        
                        <div style="margin-bottom: 15px;">
                            <label style="display: block; margin-bottom: 5px; font-weight: bold;">Port</label>
                            <input type="number" id="newPlcPort" style="width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 4px;" placeholder="Default based on protocol">
                        </div>
                        
                        <div id="s7Options" style="display: none; background: #f8f9fa; padding: 10px; border-radius: 5px; margin-bottom: 15px;">
                            <h4 style="margin: 0 0 10px 0;">Siemens S7 Options</h4>
                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
                                <div>
                                    <label>Rack</label>
                                    <input type="number" id="newPlcRack" value="0" style="width: 100%; padding: 6px; border: 1px solid #ddd; border-radius: 4px;">
                                </div>
                                <div>
                                    <label>Slot</label>
                                    <input type="number" id="newPlcSlot" value="1" style="width: 100%; padding: 6px; border: 1px solid #ddd; border-radius: 4px;">
                                </div>
                            </div>
                        </div>
                        
                        <div id="ethernetIpOptions" style="display: none; background: #f8f9fa; padding: 10px; border-radius: 5px; margin-bottom: 15px;">
                            <h4 style="margin: 0 0 10px 0;">Rockwell EtherNet/IP Options</h4>
                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
                                <div>
                                    <label>Backplane Slot</label>
                                    <input type="number" id="newPlcBackplaneSlot" value="0" style="width: 100%; padding: 6px; border: 1px solid #ddd; border-radius: 4px;" title="CPU slot on backplane (usually 0)">
                                </div>
                                <div>
                                    <label>PLC Type</label>
                                    <select id="newPlcRockwellType" style="width: 100%; padding: 6px; border: 1px solid #ddd; border-radius: 4px;">
                                        <option value="ControlLogix">ControlLogix</option>
                                        <option value="CompactLogix">CompactLogix</option>
                                        <option value="MicroLogix">MicroLogix</option>
                                        <option value="SLC500">SLC 500</option>
                                        <option value="PLC5">PLC-5</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                        
                        <div style="text-align: right; margin-top: 20px;">
                            <button type="button" onclick="closeAddPlcModal()" style="padding: 10px 20px; margin-right: 10px; border: 1px solid #ddd; background: #f8f9fa; border-radius: 5px; cursor: pointer;">Cancel</button>
                            <button type="submit" style="padding: 10px 20px; background: #3498db; color: white; border: none; border-radius: 5px; cursor: pointer;">Add PLC</button>
                        </div>
                    </form>
                </div>
            `;
            document.body.appendChild(modal);
            
            // Show/hide protocol-specific options based on selection
            document.getElementById('newPlcProtocol').addEventListener('change', function() {
                document.getElementById('s7Options').style.display = this.value === 'S7' ? 'block' : 'none';
                document.getElementById('ethernetIpOptions').style.display = this.value === 'EtherNetIP' ? 'block' : 'none';
                
                // Set default port based on protocol
                const portInput = document.getElementById('newPlcPort');
                if (!portInput.value) {
                    switch(this.value) {
                        case 'S7': portInput.placeholder = '102 (default)'; break;
                        case 'ModbusTcp': portInput.placeholder = '502 (default)'; break;
                        case 'EtherNetIP': portInput.placeholder = '44818 (default)'; break;
                        case 'ABB': portInput.placeholder = '102 (default)'; break;
                        case 'Mitsubishi': portInput.placeholder = '5007 (default)'; break;
                        case 'Omron': portInput.placeholder = '9600 (default)'; break;
                        default: portInput.placeholder = 'Default based on protocol';
                    }
                }
            });
        }
        
        modal.style.display = 'block';
    }

    function closeAddPlcModal() {
        const modal = document.getElementById('addPlcModal');
        if (modal) modal.style.display = 'none';
    }

    async function submitAddPlc(event) {
        event.preventDefault();
        
        const plcConfig = {
            plcId: document.getElementById('newPlcId').value,
            name: document.getElementById('newPlcName').value,
            protocol: document.getElementById('newPlcProtocol').value,
            ipAddress: document.getElementById('newPlcIp').value,
            port: parseInt(document.getElementById('newPlcPort').value) || null
        };
        
        if (plcConfig.protocol === 'S7') {
            plcConfig.s7Options = {
                rack: parseInt(document.getElementById('newPlcRack').value) || 0,
                slot: parseInt(document.getElementById('newPlcSlot').value) || 1
            };
        }
        
        if (plcConfig.protocol === 'EtherNetIP') {
            plcConfig.slot = parseInt(document.getElementById('newPlcBackplaneSlot').value) || 0;
            plcConfig.etherNetIpOptions = {
                path: '1,' + (parseInt(document.getElementById('newPlcBackplaneSlot').value) || 0),
                plcType: document.getElementById('newPlcRockwellType').value || 'ControlLogix',
                connectionSize: 4000,
                useConnectedMessaging: true
            };
        }
        
        try {
            const response = await fetch('/api/plc/add', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(plcConfig)
            });
            
            if (!response.ok) {
                const error = await response.text();
                throw new Error(error || 'Failed to add PLC');
            }
            
            closeAddPlcModal();
            await refreshPlcStatus();
            alert('PLC added successfully!');
            
        } catch (error) {
            alert(`Error adding PLC: ${error.message}`);
        }
    }

    // Initialize PLC tab when selected
    function initPlcGatewayTab() {
        refreshPlcStatus();
        refreshPlcValues();
        
        // Auto-refresh every 5 seconds when tab is active
        if (plcRefreshInterval) clearInterval(plcRefreshInterval);
        plcRefreshInterval = setInterval(() => {
            if (document.getElementById('plcgateway-tab').style.display !== 'none') {
                refreshPlcStatus();
                refreshPlcValues();
            }
        }, 5000);
    }

    // Hook into tab switch
    const originalSwitchTab = window.switchTab;
    window.switchTab = function(tabName) {
        originalSwitchTab(tabName);
        if (tabName === 'plcgateway') {
            initPlcGatewayTab();
        } else {
            // Stop auto-refresh when leaving PLC tab
            if (plcRefreshInterval) {
                clearInterval(plcRefreshInterval);
                plcRefreshInterval = null;
            }
        }
    };
    </script>
    
    <div style="background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%); color: white; text-align: center; padding: 20px; margin-top: 30px;">
        <p style="margin: 0; font-size: 0.95em; opacity: 0.9;">Powered by <strong>Cereveate-Praxis</strong> | Professional OPC Solutions</p>
        <p style="margin: 5px 0 0 0; font-size: 0.85em; opacity: 0.7;">© 2025 All Rights Reserved</p>
    </div>
</body>
