                            <label style="display: block; margin-bottom: 5px; font-weight: 500; color: #333;">Username:</label>
                            <select id="targetUsername" style="width: 100%; padding: 10px; border: 2px solid #ddd; border-radius: 8px; font-size: 1em;" required>
                                <option value="">Select user...</option>
                                <option value="admin">admin (Viewer)</option>
                                <option value="opcadmin">opcadmin (Administrator)</option>
