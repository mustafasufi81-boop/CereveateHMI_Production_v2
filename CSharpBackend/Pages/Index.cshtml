    async function refreshPlcStatus() {
        try {
            const response = await fetch('/api/plc/connections');
            if (!response.ok) throw new Error('Failed to fetch PLC connections');
            
            const data = await response.json();
            plcConnections = data.connections || [];
            
            // Update summary cards
            const connected = plcConnections.filter(c => c.isConnected).length;
            const disconnected = plcConnections.length - connected;
            const totalTags = plcConnections.reduce((sum, c) => sum + (c.tagCount || 0), 0);
            
            document.getElementById('plcTotalCount').textContent = plcConnections.length;
            document.getElementById('plcConnectedCount').textContent = connected;
            document.getElementById('plcDisconnectedCount').textContent = disconnected;
            document.getElementById('plcTotalTags').textContent = totalTags;
            document.getElementById('plcLastUpdate').textContent = new Date().toLocaleTimeString();
            
            // Update connections table
            renderPlcConnectionsTable();
            
            // Update filter dropdown
            updatePlcFilterDropdown();
            
        } catch (error) {
            console.error('Error refreshing PLC status:', error);
            document.getElementById('plcConnectionsBody').innerHTML = 
                '<tr><td colspan="9" style="text-align:center; color:#e74c3c;">Error loading PLC connections: ' + error.message + '</td></tr>';
        }
    }

