    async function testPlcConnection(plcId) {
        // Find connection details
        const conn = plcConnections.find(c => c.plcId === plcId);
        
        // Show loading modal
        showTestResultsModal(plcId, null, true);
        
        try {
            const requestBody = conn ? {
                ipAddress: conn.ipAddress || conn.host,
                port: conn.port,
                plcName: conn.name,
                protocol: conn.protocol
            } : {};

            const response = await fetch(`/api/plc/test/${plcId}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(requestBody)
            });
            
            if (!response.ok) {
                throw new Error(`HTTP ${response.status}: ${response.statusText}`);
            }
            
            const results = await response.json();
            showTestResultsModal(plcId, results, false);
            
        } catch (error) {
            showTestResultsModal(plcId, {
                plcId: plcId,
                overallSuccess: false,
                tests: [{
                    testName: 'API Call',
                    success: false,
                    message: `Error: ${error.message}`,
                    details: 'Failed to reach test API endpoint'
                }]
            }, false);
        }
    }

