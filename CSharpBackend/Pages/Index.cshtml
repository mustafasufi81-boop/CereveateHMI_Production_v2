        function renderHistorianChart(data, sourceFilter) {
            const canvas = document.getElementById('histTrendChart');
            const empty = document.getElementById('histTrendEmpty');
            const statsBox = document.getElementById('histStats');

            // Reset alert badges container
            let zeroOrNegativeCount = 0;
            let booleanSkippedCount = 0;

            const datasets = [];
            const stats = [];

            Object.entries(data || {}).forEach(([tagId, points], idx) => {
                // Sort by time and filter nulls
                const sorted = (points || []).slice().sort((a, b) => new Date(a.time || a.Time) - new Date(b.time || b.Time));
                const numeric = sorted.map(p => {
                    if (typeof p.value === 'boolean') {
                        booleanSkippedCount++;
                        return null;
                    }
                    const v = typeof p.value === 'number' ? p.value : parseFloat(p.value);
                    if (isNaN(v)) return null;
                    if (v <= 0) zeroOrNegativeCount++;
                    return { x: new Date(p.time || p.Time).getTime(), y: v };
                }).filter(Boolean);

                if (numeric.length === 0) return;

                const color = histPalette[idx % histPalette.length];
                datasets.push({
                    label: sourceFilter ? `${tagId} (${sourceFilter})` : tagId,
                    data: numeric,
                    borderColor: color,
                    backgroundColor: color + '33',
                    fill: false,
                    tension: 0.15,
                    pointRadius: 0
                });

                const values = numeric.map(p => p.y);
                const avg = values.reduce((a, b) => a + b, 0) / values.length;
                stats.push({
                    tagId,
                    latest: values[values.length - 1],
                    avg,
                    min: Math.min(...values),
                    max: Math.max(...values),
                    count: values.length
                });
            });

            if (histChart) {
                histChart.destroy();
                histChart = null;
            }

            if (datasets.length === 0) {
                if (canvas) canvas.style.display = 'none';
                if (empty) empty.style.display = 'block';
                if (statsBox) statsBox.innerHTML = renderHistAlerts(booleanSkippedCount, zeroOrNegativeCount);
                return;
            }

            if (canvas) canvas.style.display = 'block';
            if (empty) empty.style.display = 'none';

            histChart = new Chart(canvas.getContext('2d'), {
                type: 'line',
                data: { datasets },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: { mode: 'nearest', intersect: false },
                    scales: {
                        x: {
                            type: 'linear',
                            ticks: {
                                callback: (val) => new Date(Number(val)).toLocaleTimeString(),
                                maxRotation: 0,
                                autoSkip: true
                            }
                        },
                        y: {
                            title: { display: true, text: 'Value' },
                            beginAtZero: true,
                            suggestedMin: 0,
                            suggestedMax: 100,
                            ticks: {
                                stepSize: 10
                            }
                        }
                    },
                    plugins: {
                        legend: { position: 'top' },
                        tooltip: {
                            callbacks: {
                                label: ctx => `${ctx.dataset.label}: ${ctx.formattedValue}`
                            }
                        }
                    }
                }
            });

            // Inline badges instead of popups
            if (statsBox) {
                const alertHtml = renderHistAlerts(booleanSkippedCount, zeroOrNegativeCount);
                statsBox.insertAdjacentHTML('afterbegin', alertHtml);
            }

            renderHistStats(stats);
        }

        function renderHistAlerts(booleanSkippedCount, zeroOrNegativeCount) {
            const badges = [];
            if (booleanSkippedCount > 0) {
                badges.push(`<div style="background:#fff3cd;color:#856404;border:1px solid #ffeeba;border-radius:6px;padding:8px 12px;font-weight:600;margin-bottom:8px;">Skipped ${booleanSkippedCount} boolean samples (numeric only)</div>`);
            }
            if (zeroOrNegativeCount > 0) {
                badges.push(`<div style="background:#fdecea;color:#b71c1c;border:1px solid #f5c6cb;border-radius:6px;padding:8px 12px;font-weight:700;margin-bottom:8px;">${zeroOrNegativeCount} zero/negative values detected</div>`);
            }
            return badges.join('');
        }

        function renderHistStats(stats) {
            const box = document.getElementById('histStats');
            if (!box) return;
            if (!stats || stats.length === 0) {
                box.innerHTML = '';
                return;
            }

            box.innerHTML = stats.map(s => `
                <div class="value-card" style="background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);">
                    <div class="card-title" style="color: #fff; display:flex; justify-content: space-between; align-items:center;">
                        <span>${s.tagId}</span>
                        <span style="background:#fff3cd;color:#856404;border-radius:4px;padding:2px 6px;font-size:0.8em;">N ${s.count}</span>
                    </div>
                    <div class="card-value" style="color: #fff; font-size: 1.4em;">${s.latest?.toFixed(2)}</div>
                    <div style="display:flex; justify-content: space-between; color:#e8e8e8; font-size:0.85em;">
                        <span>Avg: ${s.avg.toFixed(2)}</span>
                        <span>Min: ${s.min.toFixed(2)}</span>
                        <span>Max: ${s.max.toFixed(2)}</span>
                    </div>
                </div>
            `).join('');
        }

